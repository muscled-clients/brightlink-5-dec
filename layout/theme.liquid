  {% render 'wsg-custom' %}

  {% if template == 'index' or template contains 'collection' %}
    <style>
      body.template-index,
      body.template-collection {
        background-color: #0A0E1A;
        color: #FFFFFF;
      }

      /* Collection page dark overrides */
      body.template-collection .page__sub-header,
      body.template-collection .breadcrumb__link,
      body.template-collection .breadcrumb__item,
      body.template-collection .collection__title,
      body.template-collection h1,
      body.template-collection h2,
      body.template-collection h3 {
        color: #FFFFFF;
      }

      body.template-collection .breadcrumb__link:hover {
        color: #0A84FF;
      }

      /* Sidebar / Filters */
      body.template-collection .card {
        background: rgba(15, 25, 40, 0.6);
        border: 1px solid rgba(60, 100, 140, 0.25);
        color: #FFFFFF;
      }

      body.template-collection .card__title--small,
      body.template-collection .card__section,
      body.template-collection .collection__filter-link,
      body.template-collection .link--primary {
        color: #FFFFFF;
      }

      body.template-collection .collection__filter-link:hover {
        color: #0A84FF;
      }

      /* Filter labels and values */
      body.template-collection .filter__toggle,
      body.template-collection .filter__label,
      body.template-collection .filter__item label,
      body.template-collection .collapsible-toggle,
      body.template-collection .collapsible-toggle__label {
        color: #FFFFFF;
      }

      body.template-collection .filter__item input[type="checkbox"] + label,
      body.template-collection .linklist__link {
        color: #A0AEC0;
      }

      /* Price range inputs */
      body.template-collection input[type="number"],
      body.template-collection .price-range__input {
        background: rgba(15, 25, 40, 0.8);
        border-color: rgba(60, 100, 140, 0.3);
        color: #FFFFFF;
      }

      /* Product cards */
      body.template-collection .product-item {
        background: #111827 !important;
        border: 1px solid rgba(60, 100, 140, 0.2);
        border-radius: 8px;
      }

      body.template-collection .product-item__info {
        background: #111827 !important;
      }

      body.template-collection .product-item__info-inner {
        background: #111827 !important;
      }

      body.template-collection .product-item__title a,
      body.template-collection .product-item__title {
        color: #FFFFFF !important;
      }

      body.template-collection .product-item__price-list,
      body.template-collection .product-item__price,
      body.template-collection .price,
      body.template-collection .price-list {
        color: #C0CCD8 !important;
      }

      body.template-collection .product-item__vendor {
        color: #8899AA !important;
      }

      body.template-collection .product-item__image-wrapper {
        background: #1a2332 !important;
      }

      body.template-collection .product-item .aspect-ratio {
        background: #1a2332 !important;
      }

      /* Product labels */
      body.template-collection .product-label {
        color: #FFFFFF;
      }

      /* Quick buy / quick view buttons */
      body.template-collection .product-item__action-list {
        background: rgba(17, 24, 39, 0.9) !important;
      }

      /* Toolbar / filter bar above product grid */
      body.template-collection .collection__toolbar,
      body.template-collection .collection__toolbar-item {
        background: #111827 !important;
        color: #C0CCD8 !important;
        border-color: rgba(60, 100, 140, 0.25) !important;
      }

      body.template-collection .collection__toolbar--bordered {
        border-color: rgba(60, 100, 140, 0.25) !important;
      }

      body.template-collection .collection__header,
      body.template-collection .collection__header-inner {
        background: #0A0E1A !important;
        color: #FFFFFF !important;
      }

      body.template-collection .collection__showing-count,
      body.template-collection .collection__products-count {
        color: #8899AA !important;
      }

      body.template-collection select,
      body.template-collection .collection__sort-by select {
        background: #0F1829 !important;
        border-color: rgba(60, 100, 140, 0.3) !important;
        color: #FFFFFF !important;
      }

      body.template-collection option {
        background: #111827;
        color: #FFFFFF;
      }

      /* Main content container background */
      body.template-collection .collection__dynamic-part,
      body.template-collection .product-list,
      body.template-collection .product-list--collection,
      body.template-collection .container,
      body.template-collection .container--flush {
        background: transparent !important;
      }

      /* Override CSS variables for dark borders */
      body.template-collection {
        --border-color: rgba(55, 65, 81, 0.5) !important;
        --secondary-background: #0A0E1A !important;
      }

      /* Dark borders between product cells */
      body.template-collection .product-item {
        border-color: rgba(55, 65, 81, 0.5) !important;
      }

      body.template-collection .product-item--vertical {
        border-color: rgba(55, 65, 81, 0.5) !important;
      }

      body.template-collection .product-list,
      body.template-collection .product-list--collection {
        background: #0A0E1A !important;
        border-color: rgba(55, 65, 81, 0.5) !important;
      }

      body.template-collection .product-list--collage::before {
        border-color: rgba(55, 65, 81, 0.5) !important;
      }

      body.template-collection .product-list--scrollable .product-item {
        border-color: rgba(55, 65, 81, 0.5) !important;
      }

      /* Recently viewed section borders */
      body.template-collection .section--recently-viewed .product-item,
      body.template-collection .section--recently-viewed .product-list {
        border-color: rgba(55, 65, 81, 0.5) !important;
        background: #0A0E1A !important;
      }

      /* View mode icons */
      body.template-collection .collection__layout-button svg {
        fill: #8899AA;
      }

      body.template-collection .collection__layout-button.is-active svg {
        fill: #FFFFFF;
      }

      /* Pagination */
      body.template-collection .pagination a,
      body.template-collection .pagination span {
        color: #C0CCD8;
      }

      body.template-collection .pagination .is-active {
        color: #0A84FF;
      }

      /* SVG icons in breadcrumb/filters */
      body.template-collection .breadcrumb svg,
      body.template-collection .icon--arrow-right {
        fill: #8899AA;
      }

      /* Collection image/banner area */
      body.template-collection .collection__image-wrapper {
        border-radius: 12px;
        overflow: hidden;
      }

      /* Recently viewed section */
      body.template-collection .section--recently-viewed {
        background: #0A0E1A !important;
        color: #FFFFFF !important;
      }

      body.template-collection .section--recently-viewed .product-item {
        background: #111827 !important;
      }

      body.template-collection .section--recently-viewed .product-item__info,
      body.template-collection .section--recently-viewed .product-item__info-inner {
        background: #111827 !important;
      }

      body.template-collection .section--recently-viewed .product-item__title a {
        color: #FFFFFF !important;
      }

      body.template-collection .section--recently-viewed .price,
      body.template-collection .section--recently-viewed .price-list {
        color: #C0CCD8 !important;
      }

      body.template-collection .section--recently-viewed .section__title,
      body.template-collection .section--recently-viewed h2 {
        color: #FFFFFF !important;
      }

      /* General overrides - catch-all for white backgrounds */
      body.template-collection .card,
      body.template-collection .card__section {
        background: #111827 !important;
        color: #FFFFFF !important;
      }

      body.template-collection .collection__main-content {
        background: transparent !important;
      }
    </style>
  {% endif %}
</head>
<body
    class="warehouse--v1 {% if settings.animation_image_zoom %}features--animate-zoom{% endif%} template-{{ request.page_type | handle }} {% if request.page_type contains '/' %}template-{{ request.page_type | split: '/' | last | handle }}{% endif %}{% if template.suffix == 'advanced-spectrum' or template.suffix == 'pro-spectrum' or template.suffix contains 'DIA-' %} advanced-spectrum-page{% endif %}"
    data-instant-intensity="viewport"
  >
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-W5TJDF8"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
      ></iframe
    ></noscript>
    <!-- End Google Tag Manager (noscript) -->

    {%- comment -%}Common SVG definitions that we are re-using in several places{%- endcomment -%}
    <svg class="visually-hidden">
      <linearGradient id="rating-star-gradient-half">
        <stop offset="50%" stop-color="var(--product-review-star-color)" />
        <stop offset="50%" stop-color="rgba(var(--text-color-rgb), .4)" stop-opacity="0.4" />
      </linearGradient>
    </svg>

    <a href="#main" class="visually-hidden skip-to-content">{{ 'general.accessibility.skip_to_content' | t }}</a>
    <span class="loading-bar"></span>

    {% section 'announcement-bar' %}

    {%- unless request.page_type == 'cart' -%}
      {%- comment -%}As required by Shopify rules, popup must be removed on cart page to remove distraction{%- endcomment -%}
      {% section 'popups' %}
    {%- endunless -%}

    {% section 'header' %}

    <main id="main" role="main">
      {%- if template.suffix == 'advanced-spectrum' or template.suffix == 'pro-spectrum' or template.suffix contains 'DIA-' -%}
        {% render 'led-hexagon-background' %}
      {%- endif -%}
      {{ content_for_layout }}
    </main>
    {%- unless template.suffix == 'advanced-spectrum' or template.suffix == 'pro-spectrum' or template.suffix contains 'DIA-' -%}
      {% section 'newsletter' %}
      {% section 'static-text-with-icons' %}
      
    {%- endunless -%}
{% section 'footer' %}
    <ul hidden>
      <li id="a11y-new-window-message">{{ 'general.accessibility.new_window' | t }}</li>
    </ul>
    {% render 'revy-bundle-script' %}





{% style %}
  {% render 'font-face' %}
{% endstyle %}          
  </body>
</html>
