{% comment %}
  Project Cost Estimator Section
  Pricing cards section with mobile accordion functionality
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.background_gradient_start }};
    background: linear-gradient(135deg, {{ section.settings.background_gradient_start }} 0%, {{ section.settings.background_gradient_end }} 100%);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  }

  #shopify-section-{{ section.id }} .estimator-container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  #shopify-section-{{ section.id }} .estimator-inner {
    background: {{ section.settings.inner_background }};
    border: 1px solid {{ section.settings.inner_border_color }};
    border-radius: {{ section.settings.inner_border_radius }}px;
    padding: 40px 45px;
  }

  #shopify-section-{{ section.id }} .estimator-header {
    text-align: left;
    margin-bottom: 24px;
  }

  #shopify-section-{{ section.id }} .estimator-title {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 15px;
    font-size: {{ section.settings.title_font_size }}px;
    font-weight: 700;
    color: {{ section.settings.title_color }};
    margin: 0;
  }

  #shopify-section-{{ section.id }} .estimator-icon {
    font-size: 32px;
    color: #fbbf24;
  }

  /* Desktop Cards Layout */
  #shopify-section-{{ section.id }} .pricing-cards {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 30px;
    margin-bottom: 40px;
    align-items: stretch;
  }

  #shopify-section-{{ section.id }} .pricing-card {
    background: {{ section.settings.card_background }};
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    padding: 30px 25px 25px 25px;
    position: relative;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .pricing-card.popular {
    border-radius: 12px;
    border: 1px solid rgba(59, 130, 246, 0.30);
    background: linear-gradient(90deg, rgba(59, 130, 246, 0.20) 0%, rgba(96, 165, 250, 0.05) 100%);
    transform: scale(1.05);
    transform-origin: center;
    z-index: 1;
    margin-bottom: -10px;
    /* background: {{ section.settings.popular_card_background }};
    background: linear-gradient(135deg, {{ section.settings.popular_gradient_start }} 0%, {{ section.settings.popular_gradient_end }} 100%);
    border: 2px solid {{ section.settings.popular_border_color }}; */
  }

  #shopify-section-{{ section.id }} .popular-badge {
    position: absolute;
    top: 1px;
    right: 1px;
    background: {{ section.settings.badge_background }};
    color: {{ section.settings.badge_text_color }};
    padding: 6px 16px;
    /* border-radius: 6px; */
    border-bottom-left-radius: 8px;
    border-top-right-radius: 8px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  #shopify-section-{{ section.id }} .card-header {
    text-align: left;
    margin-bottom: 25px;
  }

  #shopify-section-{{ section.id }} .package-name {
    font-size: {{ section.settings.package_name_font_size }}px;
    font-weight: 600;
    color: {{ section.settings.package_name_color }};
    margin-bottom: 10px;
  }

  #shopify-section-{{ section.id }} .package-price {
    font-size: {{ section.settings.package_price_font_size }}px;
    font-weight: 700;
    color: {{ section.settings.package_price_color }};
    margin: 0;
  }

  #shopify-section-{{ section.id }} .popular .package-name,
  #shopify-section-{{ section.id }} .popular .package-price {
    color: {{ section.settings.popular_text_color }};
  }

  #shopify-section-{{ section.id }} .features-list {
    list-style: none;
    padding: 0;
    margin: 0 0 20px 0;
    flex: 1;
  }

  #shopify-section-{{ section.id }} .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 14px;
    font-size: 15px;
    color: {{ section.settings.feature_text_color }};
    line-height: 1.4;
  }

  #shopify-section-{{ section.id }} .popular .feature-item {
    color: {{ section.settings.popular_feature_color }};
  }

  #shopify-section-{{ section.id }} .feature-icon {
    color: {{ section.settings.feature_icon_color }};
    font-size: 16px;
  }

  #shopify-section-{{ section.id }} .popular .feature-icon {
    color: {{ section.settings.popular_feature_icon_color }};
  }

  #shopify-section-{{ section.id }} .request-quote-btn {
    width: 100%;
    padding: {{ section.settings.button_padding_vertical }}px {{ section.settings.button_padding_horizontal }}px;
    background: transparent;
    color: {{ section.settings.button_text_color }};
    border: 2px solid rgba(139, 157, 195, 0.5);
    border-radius: {{ section.settings.button_border_radius }}px;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 500;
    text-decoration: none;
    display: inline-block;
    text-align: center;
    transition: all 0.3s ease;
    cursor: pointer;
    margin-top: auto;
  }

  #shopify-section-{{ section.id }} .request-quote-btn:hover {
    background: {{ section.settings.button_hover_background }};
    border-color: {{ section.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  #shopify-section-{{ section.id }} .popular .request-quote-btn {
    background: transparent;
    color: {{ section.settings.popular_button_text_color }};
    border-color: rgba(255, 255, 255, 0.3);
  }

  #shopify-section-{{ section.id }} .popular .request-quote-btn:hover {
    background: {{ section.settings.popular_button_hover_background }};
    border-color: {{ section.settings.popular_button_hover_border_color }};
  }

  /* Mobile Accordion Layout */
  #shopify-section-{{ section.id }} .pricing-accordions {
    display: none;
  }

  #shopify-section-{{ section.id }} .pricing-accordion {
    background: {{ section.settings.card_background }};
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    margin-bottom: 20px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .accordion-header {
    padding: 20px 20px 15px 20px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .accordion-header-content h3 {
    font-size: {{ section.settings.mobile_package_name_font_size }}px;
    font-weight: 600;
    color: {{ section.settings.package_name_color }};
    margin: 0 0 5px 0;
  }

  #shopify-section-{{ section.id }} .accordion-header-content p {
    font-size: {{ section.settings.mobile_package_price_font_size }}px;
    font-weight: 400;
    color: {{ section.settings.package_price_color }};
    margin: 0;
  }

  #shopify-section-{{ section.id }} .accordion-toggle {
    background: none;
    border: none;
    color: {{ section.settings.accordion_arrow_color }};
    font-size: 20px;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .accordion-toggle.active {
    transform: rotate(180deg);
  }

  #shopify-section-{{ section.id }} .accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  #shopify-section-{{ section.id }} .accordion-content.active {
    max-height: 800px;
  }

  #shopify-section-{{ section.id }} .accordion-body {
    padding: 0 20px 20px 20px;
  }

  /* Mobile buttons when closed */
  #shopify-section-{{ section.id }} .mobile-buttons-closed {
    display: flex;
    gap: 10px;
    padding: 0 20px 20px 20px;
  }

  #shopify-section-{{ section.id }} .view-details-btn {
    flex: 1;
    padding: 12px 20px;
    /* background: {{ section.settings.view_details_button_background }}; */
    /* color: {{ section.settings.view_details_button_text_color }}; */
    /* border: 2px solid {{ section.settings.view_details_button_border_color }}; */
    /* border-radius: 8px; */
    border-radius: 6.57px;
    border: 0 solid #E5E7EB;
    background: #FFF;
    color: #000;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
    text-align: center;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  #shopify-section-{{ section.id }} .mobile-request-btn-closed {
    flex: 1;
    padding: 12px 20px;
    /* background: {{ section.settings.button_background }}; */
    color: {{ section.settings.button_text_color }};
    /* border: 2px solid {{ section.settings.button_border_color }}; */
    /* border-radius: 8px; */
    border-radius: 6.57px;
    border: 0 solid #E5E7EB;
    background: #1E40AF;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
    text-align: center;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  /* Mobile button when open (full width) */
  #shopify-section-{{ section.id }} .mobile-request-btn-open {
    width: 100%;
    padding: {{ section.settings.button_padding_vertical }}px {{ section.settings.button_padding_horizontal }}px;
    /* background: {{ section.settings.button_background }}; */
    color: {{ section.settings.button_text_color }};
    /* border: 2px solid {{ section.settings.button_border_color }};
    border-radius: 8px; */
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
    text-align: center;
    transition: all 0.3s ease;
    cursor: pointer;
    margin-top: 20px;
    border-radius: 6.57px;
    border: 0 solid #E5E7EB;
    background: #1E40AF;
  }

  #shopify-section-{{ section.id }} .mobile-request-btn-open:hover {
    background: {{ section.settings.button_hover_background }};
    border-color: {{ section.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  /* Bottom Disclaimer */
  #shopify-section-{{ section.id }} .disclaimer {
    text-align: center;
    font-size: {{ section.settings.disclaimer_font_size }}px;
    color: {{ section.settings.disclaimer_color }};
    line-height: 1.5;
    margin: 40px 0 0 0;
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .accordion-header-content h3 {
      margin: 0;
      line-height: normal;
    }

    #shopify-section-{{ section.id }} .accordion-header-content p {
      line-height: normal;
    }
    #shopify-section-{{ section.id }} .pricing-cards {
      display: none;
    }

    #shopify-section-{{ section.id }} .pricing-accordions {
      display: block;
          border-radius: 8.76px 8.76px 8px 8px;
    border: 0 solid #E5E7EB;
    background: none;
    }

    #shopify-section-{{ section.id }} .estimator-title {
      font-size: {{ section.settings.mobile_title_font_size }}px;
      text-align: center;
      justify-content: center;
    }

    #shopify-section-{{ section.id }} .estimator-icon {
      display: none;
    }

    #shopify-section-{{ section.id }} .estimator-container {
      padding: 0 24px;
    }

    #shopify-section-{{ section.id }} .estimator-inner {
      padding: 0 0;
      background: none;
    border: none;
    padding-inline: 0;
    }

    #shopify-section-{{ section.id }} {
      padding-top: 0;
    }
  }
{%- endstyle -%}

<div class="estimator-container">
  <div class="estimator-inner">
    {% if section.settings.show_title %}
      <div class="estimator-header">
        <h2 class="estimator-title">
          {% if section.settings.section_icon != blank %}
            <span class="estimator-icon"><svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 25 25" fill="none">
  <path d="M13.723 1.34229C13.4745 0.82666 12.9495 0.498535 12.373 0.498535C11.7964 0.498535 11.2761 0.82666 11.023 1.34229L8.0089 7.54385L1.27765 8.5376C0.715146 8.62197 0.246396 9.01572 0.0729584 9.55478C-0.100479 10.0938 0.0401457 10.6892 0.443271 11.0876L5.32765 15.9204L4.17452 22.7501C4.08077 23.3126 4.31515 23.8845 4.77921 24.2173C5.24327 24.5501 5.85733 24.5923 6.36358 24.3251L12.3776 21.1142L18.3917 24.3251C18.898 24.5923 19.512 24.5548 19.9761 24.2173C20.4401 23.8798 20.6745 23.3126 20.5808 22.7501L19.423 15.9204L24.3073 11.0876C24.7105 10.6892 24.8558 10.0938 24.6776 9.55478C24.4995 9.01572 24.0355 8.62197 23.473 8.5376L16.737 7.54385L13.723 1.34229Z" fill="#60A5FA"/>
</svg></span>
          {% endif %}
          {{ section.settings.section_title }}
        </h2>
      </div>
    {% endif %}

    <!-- Desktop Cards Layout -->
    <div class="pricing-cards">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'pricing_package' %}
          <div class="pricing-card {% if block.settings.is_popular %}popular{% endif %}" {{ block.shopify_attributes }}>
            {% if block.settings.is_popular and block.settings.popular_badge_text != blank %}
              <div class="popular-badge">{{ block.settings.popular_badge_text }}</div>
            {% endif %}
            
            <div class="card-header">
              <h3 class="package-name">{{ block.settings.package_name }}</h3>
              <p class="package-price">{{ block.settings.package_price }}</p>
            </div>

            {% if block.settings.features != blank %}
              <ul class="features-list">
                {% assign features = block.settings.features | split: '|' %}
                {% for feature in features %}
                  <li class="feature-item">
                    <span class="feature-icon"><svg xmlns="http://www.w3.org/2000/svg" width="17" height="12" viewBox="0 0 17 12" fill="none">
  <path d="M15.9074 0.852287C16.3351 1.28001 16.3351 1.97463 15.9074 2.40236L7.1476 11.1621C6.71988 11.5899 6.02526 11.5899 5.59753 11.1621L1.21764 6.78225C0.78992 6.35452 0.78992 5.6599 1.21764 5.23217C1.64537 4.80445 2.33999 4.80445 2.76771 5.23217L6.37428 8.83532L14.3607 0.852287C14.7885 0.424563 15.4831 0.424563 15.9108 0.852287H15.9074Z" fill="#60A5FA"/>
</svg></span>
                    {{ feature | strip }}
                  </li>
                {% endfor %}
              </ul>
            {% endif %}

            {% if block.settings.button_text != blank %}
              <a href="{{ block.settings.button_link }}" class="request-quote-btn" target="_blank" rel="noopener noreferrer">
                {{ block.settings.button_text }}
              </a>
            {% endif %}
          </div>
      {% endcase %}
    {% endfor %}
  </div>

  <!-- Mobile Accordion Layout -->
  <div class="pricing-accordions">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'pricing_package' %}
          <div class="pricing-accordion" data-accordion-id="{{ block.id }}" {{ block.shopify_attributes }}>
            <div class="accordion-header" onclick="toggleAccordion('{{ block.id }}')">
              <div class="accordion-header-content">
                <h3>{{ block.settings.package_name }}</h3>
                <p>{{ block.settings.package_price }}</p>
              </div>
              <button class="accordion-toggle" id="toggle-{{ block.id }}">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="10" viewBox="0 0 16 10" fill="none">
  <path d="M6.94739 8.751C7.37511 9.17872 8.06974 9.17872 8.49746 8.751L15.0673 2.18117C15.495 1.75344 15.495 1.05882 15.0673 0.631095C14.6396 0.203372 13.9449 0.203372 13.5172 0.631095L7.72072 6.4276L1.92421 0.634517C1.49648 0.206793 0.801861 0.206793 0.374137 0.634517C-0.0535861 1.06224 -0.0535861 1.75686 0.374137 2.18459L6.94397 8.75442L6.94739 8.751Z" fill="white"/>
</svg>
              </button>
            </div>

            <!-- Buttons when accordion is closed -->
            <div class="mobile-buttons-closed" id="closed-buttons-{{ block.id }}">
              {% if block.settings.view_details_text != blank %}
                <button class="view-details-btn" onclick="toggleAccordion('{{ block.id }}')">
                  {{ block.settings.view_details_text }}
                </button>
              {% endif %}
              {% if block.settings.button_text != blank %}
                <a href="{{ block.settings.button_link }}" class="mobile-request-btn-closed" target="_blank" rel="noopener noreferrer">
                  {{ block.settings.button_text }}
                </a>
              {% endif %}
            </div>
            
            <div class="accordion-content {% if forloop.first %}active{% endif %}" id="content-{{ block.id }}">
              <div class="accordion-body">
                {% if block.settings.features != blank %}
                  <ul class="features-list">
                    {% assign features = block.settings.features | split: '|' %}
                    {% for feature in features %}
                      <li class="feature-item">
                        <span class="feature-icon"><svg xmlns="http://www.w3.org/2000/svg" width="17" height="12" viewBox="0 0 17 12" fill="none">
  <path d="M15.9074 0.852287C16.3351 1.28001 16.3351 1.97463 15.9074 2.40236L7.1476 11.1621C6.71988 11.5899 6.02526 11.5899 5.59753 11.1621L1.21764 6.78225C0.78992 6.35452 0.78992 5.6599 1.21764 5.23217C1.64537 4.80445 2.33999 4.80445 2.76771 5.23217L6.37428 8.83532L14.3607 0.852287C14.7885 0.424563 15.4831 0.424563 15.9108 0.852287H15.9074Z" fill="#60A5FA"/>
</svg></span>
                        {{ feature | strip }}
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}

                <!-- Full width button when accordion is open -->
                {% if block.settings.button_text != blank %}
                  <a href="{{ block.settings.button_link }}" class="mobile-request-btn-open" target="_blank" rel="noopener noreferrer">
                    {{ block.settings.button_text }}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
      {% endcase %}
    {% endfor %}
  </div>

    {% if section.settings.disclaimer_text != blank %}
      <div class="disclaimer">
        {{ section.settings.disclaimer_text }}
      </div>
    {% endif %}
  </div>
</div>

<script>
function toggleAccordion(blockId) {
  const sectionId = '{{ section.id }}';
  const section = document.getElementById('shopify-section-' + sectionId);
  
  // Get all accordion elements
  const allContents = section.querySelectorAll('.accordion-content');
  const allToggles = section.querySelectorAll('.accordion-toggle');
  const allClosedButtons = section.querySelectorAll('.mobile-buttons-closed');
  
  // Close all accordions and show closed buttons
  allContents.forEach(content => {
    content.classList.remove('active');
  });
  
  allToggles.forEach(toggle => {
    toggle.classList.remove('active');
  });

  allClosedButtons.forEach(buttons => {
    buttons.style.display = 'flex';
  });
  
  // Open the clicked accordion and hide its closed buttons
  const targetContent = section.querySelector('#content-' + blockId);
  const targetToggle = section.querySelector('#toggle-' + blockId);
  const targetClosedButtons = section.querySelector('#closed-buttons-' + blockId);
  
  if (targetContent && targetToggle && targetClosedButtons) {
    // Check if this accordion is already active (clicking to close)
    const isCurrentlyActive = targetContent.classList.contains('active');
    
    if (!isCurrentlyActive) {
      // Open this accordion and hide its closed buttons
      targetContent.classList.add('active');
      targetToggle.classList.add('active');
      targetClosedButtons.style.display = 'none';
    } else {
      // If clicking the active accordion, just close it (closed buttons already shown above)
      targetContent.classList.remove('active');
      targetToggle.classList.remove('active');
    }
  }
}

// Initialize first accordion as open on mobile
document.addEventListener('DOMContentLoaded', function() {
  const sectionId = '{{ section.id }}';
  const section = document.getElementById('shopify-section-' + sectionId);
  
  if (window.innerWidth <= 768) {
    const firstAccordion = section.querySelector('.pricing-accordion');
    if (firstAccordion) {
      const firstBlockId = firstAccordion.getAttribute('data-accordion-id');
      const firstToggle = section.querySelector('#toggle-' + firstBlockId);
      const firstClosedButtons = section.querySelector('#closed-buttons-' + firstBlockId);
      
      if (firstToggle) {
        firstToggle.classList.add('active');
      }
      if (firstClosedButtons) {
        firstClosedButtons.style.display = 'none';
      }
    }
  }
});
</script>

{% schema %}
{
  "name": "Project Cost Estimator",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Section Title",
      "default": true
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Project Cost Estimator"
    },
    {
      "type": "text",
      "id": "section_icon",
      "label": "Section Icon",
      "default": "⭐"
    },
    {
      "type": "text",
      "id": "disclaimer_text",
      "label": "Disclaimer Text",
      "default": "Prices are estimates only. Contact us for a detailed quote specific to your project requirements."
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum Width",
      "min": 800,
      "max": 1600,
      "step": 40,
      "default": 1240,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Section Padding Top",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 10,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Design & Colors"
    },
    {
      "type": "color",
      "id": "background_gradient_start",
      "label": "Background Gradient Start",
      "default": "#1e3c72"
    },
    {
      "type": "color",
      "id": "background_gradient_end",
      "label": "Background Gradient End",
      "default": "#2a5298"
    },
    {
      "type": "color",
      "id": "inner_background",
      "label": "Inner Container Background",
      "default": "rgba(30, 41, 59, 0.4)"
    },
    {
      "type": "color",
      "id": "inner_border_color",
      "label": "Inner Container Border Color",
      "default": "rgba(71, 85, 105, 0.5)"
    },
    {
      "type": "range",
      "id": "inner_border_radius",
      "label": "Inner Container Border Radius",
      "min": 10,
      "max": 30,
      "step": 5,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#ffffff"
    },
