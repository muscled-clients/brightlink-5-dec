  </defs>
</svg>
          </span>
        {% endif %}
        <h3>{{ section.settings.contact_header_text }}</h3>
      </div>

      <div class="contact-info">
        {% if section.settings.phone_number != blank %}
          <div class="contact-item phone-item">
            <div class="contact-details">
              <div class="contact-label"><span class="contact-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
