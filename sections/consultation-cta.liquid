</svg></span>
          {{ section.settings.main_button_text }}
        </a>
      {% endif %}

      {% if section.settings.mini_title != blank %}
        <div class="consultation-mini-title">
          {% if section.settings.mini_title_icon != blank %}
            <span class="star-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="15" viewBox="0 0 16 15" fill="none">
  <path d="M8.66523 1.24219C8.52031 0.941406 8.21406 0.75 7.87773 0.75C7.5414 0.75 7.23789 0.941406 7.09023 1.24219L5.33203 4.85977L1.40547 5.43945C1.07734 5.48867 0.803902 5.71836 0.702731 6.03281C0.601559 6.34727 0.68359 6.69453 0.918746 6.92695L3.76797 9.74609L3.09531 13.7301C3.04062 14.0582 3.17734 14.3918 3.44804 14.5859C3.71875 14.7801 4.07695 14.8047 4.37226 14.6488L7.88047 12.7758L11.3887 14.6488C11.684 14.8047 12.0422 14.7828 12.3129 14.5859C12.5836 14.3891 12.7203 14.0582 12.6656 13.7301L11.9902 9.74609L14.8394 6.92695C15.0746 6.69453 15.1594 6.34727 15.0555 6.03281C14.9516 5.71836 14.6809 5.48867 14.3527 5.43945L10.4234 4.85977L8.66523 1.24219Z" fill="#FACC15"/>
</svg></span>
          {% endif %}
          {{ section.settings.mini_title }}
        </div>
      {% endif %}

      <div class="consultation-action-buttons">
