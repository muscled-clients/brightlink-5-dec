{% comment %}
  Consultation CTA Section
  Call-to-action section with consultation form and contact information
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    position: relative;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    overflow: hidden;
    width: 100vw;
    /* margin-left: 50%;
    transform: translateX(-50%); */
  }

  #shopify-section-{{ section.id }} .consultation-background-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  #shopify-section-{{ section.id }} .consultation-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity }};
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .consultation-container {
    position: relative;
    z-index: 2;
    max-width: 1240px;
    width: 100%;
    margin: 0 auto;
    padding: 40px 40px;
    justify-content: space-between;
    display: flex;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .consultation-left {
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .consultation-title {
    font-size: 75px;
    font-weight: 700;
    line-height: 85px;
    margin-bottom: 25px;
    color: #ffffff;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
  }

  #shopify-section-{{ section.id }} .consultation-subtitle {
    font-size: 20px;
    margin-bottom: 20px;
    line-height: 18.8px;
    color: #ffffff;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
  }

  #shopify-section-{{ section.id }} .consultation-main-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 35px;
    background: #ffffff;
    line-height: normal;
    color: #000000;
    text-decoration: none;
    border-radius: 10px;
    font-size: 18px;
    font-weight: 600;
    transition: all 0.3s ease;
    margin-bottom: 21px;
  }

   #shopify-section-{{ section.id }} .consultation-main-btn span {
    display: flex;
   }

  #shopify-section-{{ section.id }} .consultation-main-btn:hover {
    background: {{ section.settings.main_button_hover_background }};
    transform: translateY(-2px);
  }

  #shopify-section-{{ section.id }} .consultation-mini-title {
        display: flex;
    align-items: center;
    gap: 8px;
    font-size: 20px;
    line-height: 18.8px;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
  }

  #shopify-section-{{ section.id }} .consultation-mini-title .star-icon {
    /* font-size: 18px;
    color: {{ section.settings.accent_color }}; */
    display: flex;
  }

  #shopify-section-{{ section.id }} .consultation-action-buttons {
        display: flex;
    gap: 15px;
  }

  #shopify-section-{{ section.id }} .consultation-action-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 25px;
    background: rgba(0, 0, 0, 0.65);
    color: #ffffff;
    text-decoration: none;
    border-radius: 10px;
    font-size: 16px;
    font-weight: 500;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.30);
  }

  #shopify-section-{{ section.id }} .consultation-action-btn span {
    display: flex;
  }

  #shopify-section-{{ section.id }} .consultation-action-btn:hover {
    /* background: {{ section.settings.action_button_hover_background }}; */
    transform: translateY(-1px);
  }

  #shopify-section-{{ section.id }} .consultation-right {
        /* background: #1e2a47cc; */
    background: rgba(0, 0, 0, 0.50);
    padding: 33px;
    max-width: 412px;
    width: 100%;
    /* backdrop-filter: blur(10px); */
    -webkit-backdrop-filter: blur(10px);
    border-radius: 16px;
border: 1px solid rgba(255, 255, 255, 0.20);
background: rgba(0, 0, 0, 0.50);
  }

  #shopify-section-{{ section.id }} .contact-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    /* padding-bottom: 20px; */
    /* border-bottom: 1px solid rgba(255, 255, 255, 0.1); */
  }

  #shopify-section-{{ section.id }} .contact-header .headset-icon {
    /* font-size: 24px;
    color: {{ section.settings.contact_accent_color }}; */
    display: flex;
  }

  #shopify-section-{{ section.id }} .contact-header h3 {
    font-size: 24px;
    font-weight: 700;
    line-height: normal;
    color: #ffffff;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .contact-info {
    margin-bottom: 24px;
  }

  #shopify-section-{{ section.id }} .contact-item {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  #shopify-section-{{ section.id }} .contact-item.phone-item {
    padding: 16px 16px 18px 16px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    margin-bottom: 24px;
  }

  #shopify-section-{{ section.id }} .contact-item.regular-item {
    padding: 8px 0;
    background: transparent;
  }

  #shopify-section-{{ section.id }} .contact-item:last-child {
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .contact-icon {
    font-size: 18px;
    color: {{ section.settings.contact_accent_color }};
    width: 20px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .contact-details {
    flex: 1;
  }

  #shopify-section-{{ section.id }} .contact-label {
    font-size: 16px;
    color: #fff;
    font-weight: 600;
    line-height: 24px;
    margin-bottom: 2px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  #shopify-section-{{ section.id }} .contact-value {
    font-size: 16px;
    color: #ffffff;
    font-weight: 500;
    line-height: 24px;
  }

  #shopify-section-{{ section.id }} .contact-phone {
    font-size: 24px;
    font-weight: 700;
    line-height: normal;
  }

  #shopify-section-{{ section.id }} .availability-section {
    padding: 17px;
    background: rgba(34, 197, 94, 0.15);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 12px;
    margin-top: 0;
  }

  #shopify-section-{{ section.id }} .availability-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  #shopify-section-{{ section.id }} .availability-status {
    /* width: 8px;
    height: 8px;
    border-radius: 50%;
    background: {{ section.settings.status_color }}; */
    display: flex;
  }

  #shopify-section-{{ section.id }} .availability-text {
    font-size: 16px;
    font-weight: 600;
    color: #ffffff;
  }

  #shopify-section-{{ section.id }} .availability-details {
        font-size: 14px;
    color: #a8c5e5;
    line-height: normal;
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .consultation-container {
      /* grid-template-columns: 1fr; */
      flex-direction: column;
      gap: 50px;
      padding: 40px 18px 25px 18px;
    }

    #shopify-section-{{ section.id }} .consultation-title {
      font-size: 32px;
        line-height: 36.1px;
        margin-bottom: 9px;
        text-align: center;
    }

    #shopify-section-{{ section.id }} .consultation-subtitle {
              font-size: 20px;
        font-weight: 700;
        letter-spacing: -0.769px;
        text-align: center;
        margin-bottom: 19px;
    }

    #shopify-section-{{ section.id }} .consultation-main-btn {
              width: 100%;
        color: #0C1222;
        padding-block: 13px;
        font-size: 18px;
        font-weight: 500;
        margin-bottom: 18px;
        justify-content: center;
    }

    #shopify-section-{{ section.id }} .consultation-mini-title {
      font-size: 20.045px;
    font-style: normal;
    font-weight: 700;
    line-height: 18.938px;
    letter-spacing: -0.769px;
    text-align: center;
    justify-content: center;
    margin-bottom: 18px;
    }

    #shopify-section-{{ section.id }} .consultation-action-buttons {
      /* flex-direction: column; */
      gap: 9px;
    }

    #shopify-section-{{ section.id }} .consultation-action-btn {
      width: 100%;
        justify-content: center;
        padding-block: 12.44px;
        padding-inline: 18px;
        line-height: normal;
        letter-spacing: normal;
    }

    #shopify-section-{{ section.id }} .consultation-right {
      padding: 20px;
    }

    #shopify-section-{{ section.id }} .contact-header {
          display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    /* padding-bottom: 20px; */
    /* border-bottom: 1px solid rgba(255, 255, 255, 0.1); */
    }

    #shopify-section-{{ section.id }} .contact-info {
      margin-bottom: 24px;
    }

    #shopify-section-{{ section.id }} .contact-item.phone-item {
      margin-bottom: 22px;
    }

    #shopify-section-{{ section.id }} .contact-label {
      gap: 8px;
    font-size: 15px;
    margin-bottom: 6px;
    }

    #shopify-section-{{ section.id }} .contact-icon {
      width: 15px;
    }

    #shopify-section-{{ section.id }} .contact-phone {
      font-size: 24px;
    font-weight: 700;
    line-height: normal;
    }

    #shopify-section-{{ section.id }} .contact-item.regular-item {
      padding: 8px 0; */
    background: transparent;
    margin-bottom: 11px;
    line-height: 23px;
    }

    #shopify-section-{{ section.id }} .contact-item:last-child {
      margin-bottom: 0;
    }

    #shopify-section-{{ section.id }} .contact-header h3 {
      font-size: {{ section.settings.mobile_contact_title_font_size }}px;
    }
  }
{%- endstyle -%}

<section id="shopify-section-{{ section.id }}">
  {% if section.settings.background_image %}
    {{ section.settings.background_image | image_url: width: 1920 | image_tag: class: 'consultation-background-image', loading: 'lazy' }}
  {% endif %}
  
  <div class="consultation-overlay"></div>
  
  <div class="consultation-container">
    <div class="consultation-left">
      <h2 class="consultation-title">{{ section.settings.title }}</h2>
      <p class="consultation-subtitle">{{ section.settings.subtitle }}</p>
      
      {% if section.settings.main_button_text != blank %}
        <a href="{{ section.settings.main_button_link }}" class="consultation-main-btn" target="_blank" rel="noopener noreferrer">
