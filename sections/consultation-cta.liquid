</svg></span>
           
            {{ section.settings.request_button_text }}
          </a>
        {% endif %}

        {% if section.settings.download_button_text != blank %}
          <a href="{{ section.settings.pdf_file_url | default: '#' }}" class="consultation-action-btn" {% if section.settings.pdf_file_url != blank %}target="_blank"{% endif %}>
            
