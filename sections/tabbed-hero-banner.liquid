{% comment %}
  Tabbed Hero Banner Section
  Hero banner with tabs, title, subtitle, CTA buttons and background image
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    position: relative;
    overflow: hidden;
    min-height: {{ section.settings.min_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    width: 100vw;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  }

  #shopify-section-{{ section.id }} .hero-background-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity }};
    z-index: 1;
  }

  #shopify-section-{{ section.id }} .hero-background-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  #shopify-section-{{ section.id }} .hero-background-image.mobile-bg {
    display: none;
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .hero-background-image.desktop-bg {
      display: {% if section.settings.mobile_background_image %}none{% else %}block{% endif %};
    }

    #shopify-section-{{ section.id }} .hero-background-image.mobile-bg {
      display: {% if section.settings.mobile_background_image %}block{% else %}none{% endif %};
    }
  }

  #shopify-section-{{ section.id }} .hero-content-wrapper {
    position: relative;
    z-index: 2;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .hero-tabs-container {
    display: flex;
    justify-content: center;
    gap: {{ section.settings.tab_gap }}px;
    margin-bottom: {{ section.settings.tabs_margin_bottom }}px;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .hero-tab {
    padding: {{ section.settings.tab_padding_vertical }}px {{ section.settings.tab_padding_horizontal }}px;
    background: {{ section.settings.tab_background }};
    /* border: 2px solid {{ section.settings.tab_border_color }}; */
    border-radius: {{ section.settings.tab_border_radius }}px;
    color: {{ section.settings.tab_text_color }};
    font-size: {{ section.settings.tab_font_size }}px;
    font-weight: {{ section.settings.tab_font_weight }};
    cursor: default;
    position: relative;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  #shopify-section-{{ section.id }} .hero-tab-content {
    display: none;
  }

  #shopify-section-{{ section.id }} .hero-tab-content.active {
    display: block;
  }

  #shopify-section-{{ section.id }} .hero-title {
    font-size: {{ section.settings.title_font_size }}px;
    font-weight: {{ section.settings.title_font_weight }};
    color: {{ section.settings.title_color }};
    margin-bottom: {{ section.settings.title_margin_bottom }}px;
    line-height: {{ section.settings.title_line_height }};
    text-shadow: {{ section.settings.text_shadow }};
  }

  #shopify-section-{{ section.id }} .hero-subtitle {
    font-size: {{ section.settings.subtitle_font_size }}px;
    color: {{ section.settings.subtitle_color }};
    margin-bottom: {{ section.settings.subtitle_margin_bottom }}px;
    line-height: {{ section.settings.subtitle_line_height }};
    max-width: {{ section.settings.subtitle_max_width }}px;
    margin-left: auto;
    margin-right: auto;
    text-shadow: {{ section.settings.text_shadow }};
  }

  #shopify-section-{{ section.id }} .hero-buttons-container {
    display: flex;
    justify-content: center;
    gap: {{ section.settings.button_gap }}px;
    flex-wrap: wrap;
  }

  #shopify-section-{{ section.id }} .hero-button {
    padding: {{ section.settings.button_padding_vertical }}px {{ section.settings.button_padding_horizontal }}px;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: {{ section.settings.button_font_weight }};
    border-radius: {{ section.settings.button_border_radius }}px;
    text-decoration: none;
    display: inline-block;
    transition: all 0.3s ease;
    cursor: pointer;
    border: 2px solid transparent;
  }

  #shopify-section-{{ section.id }} .hero-button-primary {
    background: {{ section.settings.primary_button_background }};
    color: {{ section.settings.primary_button_text_color }};
    border-color: {{ section.settings.primary_button_border_color }};
  }

  #shopify-section-{{ section.id }} .hero-button-primary:hover {
    background: {{ section.settings.primary_button_hover_background }};
    border-color: {{ section.settings.primary_button_hover_border_color }};
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  #shopify-section-{{ section.id }} .hero-button-secondary {
    background: {{ section.settings.secondary_button_background }};
    color: {{ section.settings.secondary_button_text_color }};
    border-color: {{ section.settings.secondary_button_border_color }};
  }

  #shopify-section-{{ section.id }} .hero-button-secondary:hover {
    background: {{ section.settings.secondary_button_hover_background }};
    border-color: {{ section.settings.secondary_button_hover_border_color }};
    color: {{ section.settings.secondary_button_hover_text_color }};
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} {
      min-height: {{ section.settings.mobile_min_height }}px;
    }

    #shopify-section-{{ section.id }} .hero-tabs-container {
      display: {{ section.settings.show_tabs_mobile | default: 'none' }};
    }

    #shopify-section-{{ section.id }} .hero-title {
      font-size: {{ section.settings.mobile_title_font_size }}px;
      line-height: 1.2;
      margin-bottom: 15px;
    }

    #shopify-section-{{ section.id }} .hero-subtitle {
      font-size: {{ section.settings.mobile_subtitle_font_size }}px;
      line-height: 1.4;
      margin-bottom: 36px;
      padding: 0 10px;
    }

    #shopify-section-{{ section.id }} .hero-tab {
      font-size: {{ section.settings.mobile_tab_font_size }}px;
      padding: {{ section.settings.mobile_tab_padding_vertical }}px {{ section.settings.mobile_tab_padding_horizontal }}px;
    }

    #shopify-section-{{ section.id }} .hero-button {
      font-size: {{ section.settings.mobile_button_font_size }}px;
      padding: {{ section.settings.mobile_button_padding_vertical }}px {{ section.settings.mobile_button_padding_horizontal }}px;
      width: 100%;
      max-width: none;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .hero-buttons-container {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
      padding: 0 17px;
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .hero-content-wrapper {
      padding: 0 24px;
    }
  }
{%- endstyle -%}

<section id="shopify-section-{{ section.id }}">
  {% if section.settings.background_image %}
    {{ section.settings.background_image | image_url: width: 1920 | image_tag: class: 'hero-background-image desktop-bg', loading: 'lazy' }}
  {% endif %}
  
  {% if section.settings.mobile_background_image %}
    {{ section.settings.mobile_background_image | image_url: width: 768 | image_tag: class: 'hero-background-image mobile-bg', loading: 'lazy' }}
  {% endif %}
  
  <div class="hero-background-overlay"></div>
  
  <div class="hero-content-wrapper">
    {% if section.blocks.size > 0 %}
      <div class="hero-tabs-container">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'tab' %}
              <div class="hero-tab" {{ block.shopify_attributes }}>
                {{ block.settings.tab_title }}
              </div>
          {% endcase %}
        {% endfor %}
      </div>
    {% endif %}

    <div class="hero-content">
      <h1 class="hero-title">{{ section.settings.default_title }}</h1>
      <p class="hero-subtitle">{{ section.settings.default_subtitle }}</p>
      
      <div class="hero-buttons-container">
        {% if section.settings.default_primary_button_text != blank %}
          <a href="{{ section.settings.default_primary_button_link }}"
             class="hero-button hero-button-primary"
             {% if section.settings.default_primary_button_link contains '#' %}data-smooth-scroll="true"{% endif %}>
            {{ section.settings.default_primary_button_text }}
          </a>
        {% endif %}
        
        {% if section.settings.default_secondary_button_text != blank %}
          <a href="{{ section.settings.default_secondary_button_link }}"
             class="hero-button hero-button-secondary"
             target="_blank" rel="noopener noreferrer">
            {{ section.settings.default_secondary_button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-smooth-scroll="true"]').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      var href = this.getAttribute('href');
      if (href && href.startsWith('#')) {
        var id = href.slice(1);
        // Try exact match first, then partial match (Shopify prepends template ID)
        var target = document.getElementById(id) || document.querySelector('[id$="__' + id + '"]') || document.querySelector('[id*="' + id + '"]');
        if (target) {
          e.preventDefault();
          var stickyBar = document.querySelector('.sticky-site-header') || document.querySelector('#shopify-section-header');
          var headerHeight = stickyBar ? stickyBar.offsetHeight : 0;
          var top = target.getBoundingClientRect().top + window.pageYOffset - headerHeight;
          window.scrollTo({ top: top, behavior: 'smooth' });
        }
      }
    });
  });
</script>

