<style>
  #shopify-section-{{ section.id }} .featured-products {
    position: relative;
    padding: 120px 0;
    color: #FFFFFF;
  }
  #shopify-section-{{ section.id }} .featured-products__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: #0A0E1A;
  }
  #shopify-section-{{ section.id }} .featured-products__bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.9;
  }
  #shopify-section-{{ section.id }} .featured-products__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10, 14, 26, 0.9) 0%, rgba(10, 14, 26, 0.8) 100%);
  }
  #shopify-section-{{ section.id }} .featured-products__container {
    position: relative;
    z-index: 1;
    {% comment %} max-width: 1440px; {% endcomment %}
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    {% comment %} flex-direction: column; {% endcomment %}
    {% comment %} gap: 40px; {% endcomment %}
  display: flex;
width: 1350px;
flex-direction: column;
justify-content: center;
{% comment %} align-items: center; {% endcomment %}
gap: 120px;
  }

  #shopify-section-{{ section.id }} .featured-products__eyebrow {
    display: inline-flex;
    align-items: center;
    color: #D4AF37;
    font-family: "Inter", "Open Sans", sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.7px;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .featured-products__title {
    color: #FFFFFF;
    font-family: "Inter", "Open Sans", sans-serif;
    font-size: 48px;
    font-weight: 700;
    letter-spacing: -2px;
    margin-top: 8px;
  }
  #shopify-section-{{ section.id }} .featured-products__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
  }
  #shopify-section-{{ section.id }} .featured-products__controls {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 8px;
  }
  #shopify-section-{{ section.id }} .featured-products__nav {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    border: 1px solid rgba(10, 132, 255, 0.25);
    background: #0A0E1A;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
    
  }
  #shopify-section-{{ section.id }} .featured-products__nav img {
    width: 40px;
    height: 40px;
    display: block;
  }
  #shopify-section-{{ section.id }} .featured-products__viewport {
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .featured-products__track {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    padding-bottom: 4px;
  }
  #shopify-section-{{ section.id }} .featured-products__track::-webkit-scrollbar {
    display: none;
  }
  #shopify-section-{{ section.id }} .featured-products__card {
    flex: 0 0 240px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 16px;
    border-radius: 8px;
    border: 1px solid rgba(10, 132, 255, 0.25);
    background: #0A0E1A;
    color: #FFFFFF;
    text-decoration: none;
    scroll-snap-align: start;
  }
  #shopify-section-{{ section.id }} .featured-products__image {
    width: 100%;
    padding: 16px;
    border-radius: 6px;
    background: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 140px;
  }
  #shopify-section-{{ section.id }} .featured-products__image img {
    max-width: 100%;
    height: auto;
    display: block;
  }
  #shopify-section-{{ section.id }} .featured-products__card-title {
    color: #FFFFFF;
    font-family: "Inter", "Open Sans", sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: normal;
  }
  #shopify-section-{{ section.id }} .featured-products__card-desc {
    color: #A0AEC0;
    font-family: "Inter", "Open Sans", sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 18px;
  }
  #shopify-section-{{ section.id }} .featured-products__card-price {
    color: #FFFFFF;
    font-family: "Inter", "Open Sans", sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: normal;
  }
  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .featured-products {
      padding: 80px 0;
    }
    #shopify-section-{{ section.id }} .featured-products__title {
      font-size: 36px;
      letter-spacing: -1px;
    }
    #shopify-section-{{ section.id }} .featured-products__header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
  @media (max-width: 600px) {
    #shopify-section-{{ section.id }} .featured-products__card {
      flex-basis: 220px;
    }
  }
</style>

<section class="featured-products" data-section-id="{{ section.id }}">
  <div class="featured-products__bg">
    {% if section.settings.background_image != blank %}
      <img class="featured-products__bg-image" src="{{ section.settings.background_image | image_url: width: 2200 }}" alt="{{ section.settings.background_image.alt | escape }}">
    {% endif %}
    <div class="featured-products__bg-overlay"></div>
  </div>
  <div class="featured-products__container">
    <div class="featured-products__header">
      <div>
        <span class="featured-products__eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 class="featured-products__title">{{ section.settings.title }}</h2>
      </div>
      <div class="featured-products__controls">
        <button class="featured-products__nav featured-products__nav--prev" type="button" aria-label="Previous">
          {% if section.settings.arrow_left != blank %}
            <img src="{{ section.settings.arrow_left | image_url: width: 40 }}" alt="{{ section.settings.arrow_left.alt | escape }}">
          {% endif %}
        </button>
        <button class="featured-products__nav featured-products__nav--next" type="button" aria-label="Next">
          {% if section.settings.arrow_right != blank %}
            <img src="{{ section.settings.arrow_right | image_url: width: 40 }}" alt="{{ section.settings.arrow_right.alt | escape }}">
          {% endif %}
        </button>
      </div>
    </div>
    <div class="featured-products__viewport">
      <div class="featured-products__track">
        {% for block in section.blocks %}
          <a class="featured-products__card" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
            <div class="featured-products__image">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.image.alt | escape }}">
              {% endif %}
            </div>
            <div>
              <div class="featured-products__card-title">{{ block.settings.title }}</div>
              <div class="featured-products__card-desc">{{ block.settings.description }}</div>
              <div class="featured-products__card-price">{{ block.settings.price }}</div>
            </div>
          </a>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;
    var track = section.querySelector('.featured-products__track');
    var prev = section.querySelector('.featured-products__nav--prev');
    var next = section.querySelector('.featured-products__nav--next');
    if (!track || !prev || !next) return;
    var card = track.querySelector('.featured-products__card');
    var gap = 0;
    if (window.getComputedStyle) {
      var styles = window.getComputedStyle(track);
      gap = parseInt(styles.gap || '0', 10) || 0;
    }
    var scrollAmount = (card ? card.offsetWidth : 240) + gap;
    prev.addEventListener('click', function () {
      track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });
    next.addEventListener('click', function () {
      track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });
  })();
</script>

{% schema %}
{
  "name": "Featured Products",
  "max_blocks": 10,
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Featured Products"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Featured Products"
    },
    {
      "type": "image_picker",
      "id": "arrow_left",
      "label": "Arrow Left"
    },
    {
      "type": "image_picker",
      "id": "arrow_right",
      "label": "Arrow Right"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Interactive Flat Panel"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Brightlink 98\" 4K LG Interactive Display with Stand - Android 11.0 Smart OS - Windows 11 OPS Included - Wireless Screen Mirroring Built-in 4K professional camera - 8-array microphones"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$7,997.00"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Products"
    }
  ]
}
{% endschema %}