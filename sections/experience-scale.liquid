              </i>
            </div>
            <div class="experience-scale__metric-text">
              <span class="experience-scale__metric-value">{{ section.settings.metric3_value | default: '141' }}</span>
              <div class="experience-scale__metric-title-wrapper">
                <span class="experience-scale__metric-label">{{ section.settings.metric3_label | default: 'sq ft' }}</span>
                <span class="experience-scale__metric-desc">{{ section.settings.metric3_desc | default: 'of visual real estate' }}</span>
              </div>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  /* Desktop styles for info containers */
  #experience-scale-{{ section.id }} .experience-scale__info-container {
    border-radius: 8px;
    border: 1px solid rgba(10, 132, 255, 0.30);
    background: rgba(0, 0, 0, 0.55);
    display: flex;
    padding: 12px 16px;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    position: absolute;
    z-index: 10;
  }
  
  #experience-scale-{{ section.id }} .experience-scale__info-container--1 {
    right: 109px;
    top: 70px;
  }
  
  #experience-scale-{{ section.id }} .experience-scale__info-container--2 {
    right: 69px;
    top: 288.718px;
  }
  
  #experience-scale-{{ section.id }} .experience-scale__info-container--3 {
    right: 93px;
    bottom: 37px;
  }
  
  #experience-scale-{{ section.id }} .experience-scale__info-heading {
    align-self: stretch;
    color: #0A84FF;
    text-align: center;
    font-family: Inter;
    font-size: 24px;
    font-style: normal;
    font-weight: 700;
    line-height: normal;
    margin: 0;
  }
  
  #experience-scale-{{ section.id }} .experience-scale__info-subheading {
    color: #A0AEC0;
    text-align: center;
    font-family: Inter;
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    align-self: stretch;
    margin: 0;
  }
  
  /* Ensure image wrapper is positioned relative for absolute positioning of containers */
  #experience-scale-{{ section.id }} .experience-scale__image-wrapper {
    position: relative;
  }
  
  /* Image styling - DESKTOP */
  #experience-scale-{{ section.id }} .experience-scale__image {
    width: 100%;
    height: auto;
    display: block;
  }
  
  /* Show desktop image by default, hide mobile on desktop */
  #experience-scale-{{ section.id }} .experience-scale__image--desktop {
    display: block;
  }
  
  #experience-scale-{{ section.id }} .experience-scale__image--mobile {
    display: none;
  }
  
  #experience-scale-{{ section.id }} .experience-scale__image-placeholder--desktop {
    display: flex;
  }
  
  #experience-scale-{{ section.id }} .experience-scale__image-placeholder--mobile {
    display: none;
  }
  
  /* Mobile styles using media query */
  @media (max-width: 767px) {
    #experience-scale-{{ section.id }} {
      width: 375px;
      padding: 0 16px;
      margin: 0 auto;
      box-sizing: border-box;
    }
    
    #experience-scale-{{ section.id }} .experience-scale__container {
      width: 100%;
      max-width: 100%;
    }
    
    #experience-scale-{{ section.id }} .experience-scale__display {
      display: flex;
      width: 343px;
      height: 246.547px;
      padding: 16px;
      flex-direction: column;
      align-items: flex-start;
      gap: 3.343px;
      margin: 0 auto;
      box-sizing: border-box;
      align-self: stretch;
      aspect-ratio: 158 / 109;
    }
    
    #experience-scale-{{ section.id }} .experience-scale__image-wrapper {
      width: 100%;
      position: relative;
    }
    
    /* Info container mobile styles */
    #experience-scale-{{ section.id }} .experience-scale__info-container {
      border-radius: 8px;
      border: 1px solid rgba(10, 132, 255, 0.30);
      background: rgba(0, 0, 0, 0.55);
      display: flex;
      padding: 8px 12px;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      position: absolute;
      z-index: 10;
      box-sizing: border-box;
    }
    
    #experience-scale-{{ section.id }} .experience-scale__info-container--1 {
      right: 16px;
      top: 0px;
      left: auto;
    }
    
    #experience-scale-{{ section.id }} .experience-scale__info-container--2 {
      right: 21px;
      bottom: 75.547px;
      top: auto;
      left: auto;
    }
    
    #experience-scale-{{ section.id }} .experience-scale__info-container--3 {
      right: 35px;
      bottom: 0px;
      top: auto;
    }
    
    #experience-scale-{{ section.id }} .experience-scale__info-heading {
      color: #0A84FF;
      text-align: center;
      font-family: Inter;
      font-size: 14px;
      font-style: normal;
      font-weight: 700;
      line-height: normal;
      align-self: stretch;
      margin: 0;
    }
    
    #experience-scale-{{ section.id }} .experience-scale__info-subheading {
      color: #A0AEC0;
      text-align: center;
      font-family: Inter;
      font-size: 10px;
      font-style: normal;
      font-weight: 500;
      line-height: normal;
      align-self: stretch;
      margin: 0;
    }
    
    /* Hide desktop image, show mobile image on mobile */
    #experience-scale-{{ section.id }} .experience-scale__image--desktop {
      display: none;
    }
    
    #experience-scale-{{ section.id }} .experience-scale__image--mobile {
      display: block;
      height: 214.547px;
      width: 100%;
      aspect-ratio: 158/109;
      object-fit: cover;
    }
    
    #experience-scale-{{ section.id }} .experience-scale__image-placeholder--desktop {
      display: none;
    }
    
    #experience-scale-{{ section.id }} .experience-scale__image-placeholder--mobile {
      display: flex;
      height: 214.547px;
      width: 100%;
      aspect-ratio: 158/109;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0.1);
      border: 1px dashed rgba(255, 255, 255, 0.2);
      border-radius: 8px;
      flex-direction: column;
      box-sizing: border-box;
    }
    
    #experience-scale-{{ section.id }} .experience-scale__image-placeholder--mobile svg {
      width: 40px;
      height: 40px;
      color: rgba(255, 255, 255, 0.3);
      margin-bottom: 8px;
    }
    
    #experience-scale-{{ section.id }} .experience-scale__image-placeholder--mobile span {
      color: rgba(255, 255, 255, 0.5);
      font-size: 12px;
    }
  }
</style>

{% schema %}
{
  "name": "Experience Scale",
  "tag": "section",
  "class": "experience-scale-section",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section Label",
      "default": "IMMERSIVE DISPLAY"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Experience the Scale"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "217 inches of immersive visual excellence"
    },
    {
      "type": "header",
      "content": "Display Images"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Display Image",
      "info": "Recommended size: 1200x600px"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Display Image (Optional)",
      "info": "Upload a different image for mobile. If not set, desktop image will be used. Recommended aspect ratio: 158:109"
    },
    {
      "type": "header",
      "content": "Metric 1"
    },
    {
      "type": "text",
      "id": "metric1_value",
      "label": "Value",
      "default": "36x"
    },
    {
      "type": "text",
      "id": "metric1_label",
      "label": "Label",
      "default": "Larger"
    },
    {
      "type": "text",
      "id": "metric1_desc",
      "label": "Description",
      "default": "than a typical 65\" TV"
    },
    {
      "type": "header",
      "content": "Metric 2"
    },
    {
      "type": "text",
      "id": "metric2_value",
      "label": "Value",
      "default": "4x"
    },
    {
      "type": "text",
      "id": "metric2_label",
      "label": "Label",
      "default": "Equivalent"
    },
    {
      "type": "text",
      "id": "metric2_desc",
      "label": "Description",
      "default": "to 17' diagonal display"
    },
    {
      "type": "header",
      "content": "Metric 3"
    },
    {
      "type": "text",
      "id": "metric3_value",
      "label": "Value",
      "default": "141"
    },
    {
      "type": "text",
      "id": "metric3_label",
      "label": "Label",
      "default": "sq ft"
    },
    {
      "type": "text",
      "id": "metric3_desc",
      "label": "Description",
      "default": "of visual real estate"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Configure Your Display"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Info Containers"
    },
    {
      "type": "text",
      "id": "info1_heading",
      "label": "Container 1 Heading",
      "default": "Pixel Perfect"
    },
    {
      "type": "text",
      "id": "info1_subheading",
      "label": "Container 1 Subheading",
      "default": "Crystal clear visuals at any distance"
    },
    {
      "type": "text",
      "id": "info2_heading",
      "label": "Container 2 Heading",
