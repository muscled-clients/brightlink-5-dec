{{ 'visual-experience.css' | asset_url | stylesheet_tag }}

<section class="visual-experience" id="visual-experience-{{ section.id }}">
  <div class="visual-experience__container">
    <div class="visual-experience__content">
      <!-- Left Side - Slider -->
      <div class="visual-experience__slider">
        <div class="visual-experience__slides-wrapper">
          <div class="visual-experience__slides">
            {% if section.blocks.size > 0 %}
              <!-- Show slide blocks if added -->
              {% for block in section.blocks %}
                {% if block.type == 'slide' %}
                  <div
                    class="visual-experience__slide {% if forloop.first %}visual-experience__slide--active{% endif %}"
                    data-slide-index="{{ forloop.index0 }}"
                    {{ block.shopify_attributes }}
                  >
                    {% if block.settings.product != blank %}
                      {% assign slide_product = all_products[block.settings.product] %}
                      {% if slide_product.featured_image != blank %}
                        <img
                          src="{{ slide_product.featured_image | image_url: width: 800 }}"
                          alt="{{ slide_product.featured_image.alt | default: slide_product.title }}"
                          loading="lazy"
                          width="800"
                          height="500"
                        >
                      {% else %}
                        <div class="visual-experience__slide-placeholder">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <path d="M21 3H3c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H3V5h18v14zM5 15h14v3H5z"/>
                          </svg>
                        </div>
                      {% endif %}
                    {% elsif block.settings.image != blank %}
                      <img
                        src="{{ block.settings.image | image_url: width: 800 }}"
                        alt="{{ block.settings.image_alt | default: section.settings.heading }}"
                        loading="lazy"
                        width="800"
                        height="500"
                      >
                    {% else %}
                      <div class="visual-experience__slide-placeholder">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                          <path d="M21 3H3c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H3V5h18v14zM5 15h14v3H5z"/>
                        </svg>
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            {% else %}
              <!-- Show product images if no blocks added -->
              {% for image in product.images %}
                <div
                  class="visual-experience__slide {% if forloop.first %}visual-experience__slide--active{% endif %}"
                  data-slide-index="{{ forloop.index0 }}"
                >
                  <img
                    src="{{ image | image_url: width: 800 }}"
                    alt="{{ image.alt | default: product.title }}"
                    loading="lazy"
                    width="800"
                    height="500"
                  >
                </div>
              {% else %}
                <!-- Fallback placeholder if no product images -->
                <div class="visual-experience__slide visual-experience__slide--active">
                  <div class="visual-experience__slide-placeholder">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                      <path d="M21 3H3c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H3V5h18v14zM5 15h14v3H5z"/>
                    </svg>
                  </div>
                </div>
              {% endfor %}
            {% endif %}
          </div>
        </div>

        <!-- Dots Navigation (inside slides for overlay) -->
        {% if section.blocks.size > 1 %}
          <div class="visual-experience__dots">
            {% for block in section.blocks %}
              {% if block.type == 'slide' %}
                <button
                  class="visual-experience__dot {% if forloop.first %}visual-experience__dot--active{% endif %}"
                  data-dot-index="{{ forloop.index0 }}"
                  aria-label="Go to slide {{ forloop.index }}"
                ></button>
              {% endif %}
            {% endfor %}
          </div>
        {% elsif section.blocks.size == 0 and product.images.size > 1 %}
          <div class="visual-experience__dots">
            {% for image in product.images %}
              <button
                class="visual-experience__dot {% if forloop.first %}visual-experience__dot--active{% endif %}"
                data-dot-index="{{ forloop.index0 }}"
                aria-label="Go to slide {{ forloop.index }}"
              ></button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Right Side - Text Content -->
      <div class="visual-experience__text">
        <div class="visual-experience__text-content">
          {% if section.settings.heading != blank %}
            <h2 class="visual-experience__heading">{{ section.settings.heading }}</h2>
          {% endif %}

          {% if section.settings.description != blank %}
            <p class="visual-experience__description">{{ section.settings.description }}</p>
          {% endif %}
        </div>

        <!-- CTA Box -->
        <div class="visual-experience__cta">
          <a href="{{ section.settings.primary_btn_link | default: '#order' }}" class="visual-experience__btn">
            {{ section.settings.primary_btn_text | default: 'ORDER NOW' }}
          </a>

          <div class="visual-experience__cta-footer">
            <a href="{{ section.settings.secondary_btn_link | default: 'https://cal.com/tyson-edwards-brightlinkav' }}" class="visual-experience__btn--secondary">
              {{ section.settings.secondary_btn_text | default: 'BOOK A CALL' }}
            </a>
            {% if section.settings.price_text != blank %}
              <span class="visual-experience__divider"></span>
              <span class="visual-experience__price">{{ section.settings.price_text }}</span>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ONLY drag functionality CSS added - everything else unchanged */
  #visual-experience-{{ section.id }} .visual-experience__slides-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    cursor: grab;
    user-select: none;
  }

  #visual-experience-{{ section.id }} .visual-experience__slides-wrapper:active {
    cursor: grabbing;
  }

  #visual-experience-{{ section.id }} .visual-experience__slides {
    display: flex;
    transition: transform 0.3s ease;
    will-change: transform;
  }

  #visual-experience-{{ section.id }} .visual-experience__slide {
    flex: 0 0 100%;
    width: 100%;
  }

  #visual-experience-{{ section.id }} .visual-experience__slides.dragging {
    transition: none;
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const section = document.querySelector('#visual-experience-{{ section.id }}');
  if (!section) return;

  const slidesWrapper = section.querySelector('.visual-experience__slides-wrapper');
  const slidesContainer = section.querySelector('.visual-experience__slides');
  const slides = section.querySelectorAll('.visual-experience__slide');
  const dots = section.querySelectorAll('.visual-experience__dot');

  if (slides.length <= 1) return;

  let currentIndex = 0;
  let autoSlideInterval;
  let startX, moveX, currentTranslate, isDragging = false;
  let startTime, dragDistance = 0;

  // Get slide width
  function getSlideWidth() {
    return slides[0].offsetWidth;
  }

  // Set initial position
  function setSliderPosition() {
    slidesContainer.style.transform = `translateX(-${currentIndex * 100}%)`;
  }

  function goToSlide(index) {
    if (index < 0) index = 0;
    if (index >= slides.length) index = slides.length - 1;
    
    slidesContainer.style.transform = `translateX(-${index * 100}%)`;
    
    // Update active states
    slides.forEach(slide => slide.classList.remove('visual-experience__slide--active'));
    dots.forEach(dot => dot.classList.remove('visual-experience__dot--active'));

    slides[index].classList.add('visual-experience__slide--active');
    if (dots[index]) {
      dots[index].classList.add('visual-experience__dot--active');
    }
    
    currentIndex = index;
  }

  function nextSlide() {
    const next = (currentIndex + 1) % slides.length;
    goToSlide(next);
  }

  // Drag functionality
  slidesWrapper.addEventListener('mousedown', dragStart);
  slidesWrapper.addEventListener('touchstart', dragStart);
  slidesWrapper.addEventListener('mouseup', dragEnd);
  slidesWrapper.addEventListener('touchend', dragEnd);
  slidesWrapper.addEventListener('mouseleave', dragEnd);
  slidesWrapper.addEventListener('mousemove', drag);
  slidesWrapper.addEventListener('touchmove', drag);

  function dragStart(e) {
    e.preventDefault();
    if (slides.length <= 1) return;
    
    isDragging = true;
    startTime = Date.now();
    slidesContainer.classList.add('dragging');
    
    // Get starting position
    if (e.type === 'touchstart') {
      startX = e.touches[0].clientX;
    } else {
      startX = e.clientX;
    }
    
    // Get current transform value
    const transform = window.getComputedStyle(slidesContainer).transform;
    if (transform !== 'none') {
      const matrix = transform.match(/matrix.*\((.+)\)/);
      if (matrix) {
        const values = matrix[1].split(', ');
        currentTranslate = -parseFloat(values[4]) / getSlideWidth() * 100;
      } else {
        currentTranslate = currentIndex;
      }
    } else {
      currentTranslate = currentIndex;
    }
    
    clearInterval(autoSlideInterval);
  }

  function drag(e) {
    if (!isDragging) return;
    e.preventDefault();
    
    let currentX;
    if (e.type === 'touchmove') {
      currentX = e.touches[0].clientX;
    } else {
      currentX = e.clientX;
    }
    
    const diff = currentX - startX;
    dragDistance = diff;
    const dragPercent = (diff / getSlideWidth()) * 100;
    
    // Apply drag with resistance at edges
    if ((currentIndex === 0 && dragPercent > 0) || 
        (currentIndex === slides.length - 1 && dragPercent < 0)) {
      slidesContainer.style.transform = `translateX(${currentIndex * -100 - dragPercent * 0.3}%)`;
    } else {
      slidesContainer.style.transform = `translateX(${currentIndex * -100 - dragPercent}%)`;
    }
  }

  function dragEnd(e) {
    if (!isDragging) return;
    e.preventDefault();
    
    isDragging = false;
    slidesContainer.classList.remove('dragging');
    
    const dragTime = Date.now() - startTime;
    const dragSpeed = Math.abs(dragDistance) / dragTime;
    
    // Determine if we should change slide
    if (Math.abs(dragDistance) > 50 || dragSpeed > 0.5) {
      if (dragDistance > 0 && currentIndex > 0) {
        goToSlide(currentIndex - 1);
      } else if (dragDistance < 0 && currentIndex < slides.length - 1) {
        goToSlide(currentIndex + 1);
      } else {
        goToSlide(currentIndex);
      }
    } else {
      goToSlide(currentIndex);
    }
    
    startAutoSlide();
  }

  // Dot click handlers
  dots.forEach((dot, index) => {
    dot.addEventListener('click', function() {
      goToSlide(index);
      resetAutoSlide();
    });
  });

  // Auto-slide functionality
  function startAutoSlide() {
    autoSlideInterval = setInterval(nextSlide, 5000);
  }

  function resetAutoSlide() {
    clearInterval(autoSlideInterval);
    startAutoSlide();
  }

  // Start auto-slide
  startAutoSlide();

  // Pause on hover
  section.addEventListener('mouseenter', () => clearInterval(autoSlideInterval));
  section.addEventListener('mouseleave', startAutoSlide);

  // Handle window resize
  window.addEventListener('resize', () => {
    setSliderPosition();
  });

  // Initialize
  setSliderPosition();
});
</script>

{% schema %}
{
  "name": "Visual Experience",
  "tag": "section",
  "class": "visual-experience-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Elevate Your Visual Experience Today"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Transform your space with Pro Spectrum's 4K LED Video Wall. Designed for high-traffic environments, it delivers unmatched clarity and reliability. Contact us today to bring stunning visuals to your business!"
    },
    {
      "type": "header",
      "content": "CTA Buttons"
    },
    {
      "type": "text",
      "id": "primary_btn_text",
      "label": "Primary Button Text",
      "default": "ORDER NOW"
    },
    {
      "type": "url",
      "id": "primary_btn_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_btn_text",
      "label": "Secondary Button Text",
      "default": "BOOK A CALL"
    },
    {
      "type": "url",
      "id": "secondary_btn_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "text",
      "id": "price_text",
      "label": "Price Text",
      "default": "$19,250.00 (30% DEPOSIT)"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "Select a product to show its featured image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Slide Image",
          "info": "Upload a custom image (used if no product is selected)"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image Alt Text",
          "info": "Alternative text for the image (only applies to custom images)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Visual Experience",
      "category": "Custom"
    }
  ]
}
{% endschema %}