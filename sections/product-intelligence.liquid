                  <div class="support-resources__grid">
                    {% if pic_support_resource_titles and pic_support_resource_titles.size > 0 %}
                      {% for title in pic_support_resource_titles %}
                        {% assign current_index = forloop.index0 %}
                        {% assign file_url = '' %}
                        {% assign file_name = '' %}
                        {% assign file_extension = '' %}
                        {% assign icon_url = '' %}
                        {% comment %} Loop through files to find matching index {% endcomment %}
                        {% for file in pic_support_resource_files %}
                          {% if forloop.index0 == current_index %}
                            {% assign file_url = file.url %}
                            {% assign file_name = file_url | split: '/' | last | split: '?' | first %}
                            {% assign file_extension = file_name | split: '.' | last | upcase %}
                            {% break %}
                          {% endif %}
                        {% endfor %}
                        {% comment %} Loop through icons to find matching index {% endcomment %}
                        {% for icon in pic_support_resource_icons %}
                          {% if forloop.index0 == current_index %}
                            {% assign icon_url = icon.src | default: icon | image_url %}
                            {% break %}
                          {% endif %}
                        {% endfor %}
                        <div class="resource-card" data-file-url="{{ file_url }}" data-card-index="{{ current_index }}">
                          <div class="resource-card__header">
                            <div class="resource-card__icon">
                              {% if icon_url != blank %}
                                <img src="{{ icon_url }}" alt="{{ title }}">
                              {% else %}
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                  <path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/>
                                </svg>
                              {% endif %}
                            </div>
                            {% if file_url != blank %}
                              <div class="resource-card__download" onclick="downloadResourceFile('{{ file_url }}', '{{ file_name }}')">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                  <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
                                </svg>
                              </div>
                            {% endif %}
                          </div>
                          <h4 class="resource-card__title">{{ title }}</h4>
                          {% if pic_support_resource_descriptions[current_index] %}
                            <p class="resource-card__desc">{{ pic_support_resource_descriptions[current_index] }}</p>
