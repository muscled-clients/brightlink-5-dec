{{ 'product-intelligence.css' | asset_url | stylesheet_tag }}

{% comment %} ============================================
   PRODUCT INTELLIGENCE METAFIELDS
   Namespace: custom | Prefix: pic_ (Product Intelligence Content)
   ============================================ {% endcomment %}

{% comment %} Section Header {% endcomment %}
{% assign pic_label = product.metafields.custom.pic_label.value | default: section.settings.section_label %}
{% assign pic_heading = product.metafields.custom.pic_heading.value | default: section.settings.heading %}
{% assign pic_subheading = product.metafields.custom.pic_subheading.value | default: section.settings.subheading %}

{% comment %} Specifications Tab (JSON) {% endcomment %}
{% assign pic_specs_display = product.metafields.custom.pic_specs_display.value %}
{% assign pic_specs_physical = product.metafields.custom.pic_specs_physical.value %}
{% assign pic_specs_electrical = product.metafields.custom.pic_specs_electrical.value %}
{% assign pic_specs_environmental = product.metafields.custom.pic_specs_environmental.value %}

{% comment %} Specifications Tab - Download {% endcomment %}
{% assign pic_specs_download_title = product.metafields.custom.pic_specs_download_title.value %}
{% assign pic_specs_download_description = product.metafields.custom.pic_specs_download_description.value %}
{% assign pic_specs_download_file = product.metafields.custom.pic_specs_download_file.value %}

{% comment %} What's Included Tab (Lists) {% endcomment %}
{% assign pic_included_badges = product.metafields.custom.pic_included_badges.value %}
{% assign pic_included_titles = product.metafields.custom.pic_included_titles.value %}
{% assign pic_included_descriptions = product.metafields.custom.pic_included_descriptions.value %}

{% comment %} Features Tab (Lists) {% endcomment %}
{% assign pic_features_titles = product.metafields.custom.pic_features_titles.value %}
{% assign pic_features_descriptions = product.metafields.custom.pic_features_descriptions.value %}

{% comment %} Installation Tab - Steps (Lists) {% endcomment %}
{% assign pic_install_step_numbers = product.metafields.custom.pic_install_step_numbers.value %}
{% assign pic_install_step_titles = product.metafields.custom.pic_install_step_titles.value %}
{% assign pic_install_step_descriptions = product.metafields.custom.pic_install_step_descriptions.value %}
{% assign pic_install_step_durations = product.metafields.custom.pic_install_step_durations.value %}

{% comment %} Installation Tab - Requirements {% endcomment %}
{% assign pic_install_requirements_heading = product.metafields.custom.pic_install_requirements_heading.value %}
{% assign pic_install_requirements_titles = product.metafields.custom.pic_install_requirements_titles.value %}
{% assign pic_install_requirements_descriptions = product.metafields.custom.pic_install_requirements_descriptions.value %}

{% comment %} Installation Tab - Support {% endcomment %}
{% assign pic_install_support_title = product.metafields.custom.pic_install_support_title.value %}
{% assign pic_install_support_description = product.metafields.custom.pic_install_support_description.value %}
{% assign pic_install_support_button = product.metafields.custom.pic_install_support_button.value %}

{% comment %} Support Tab - Header & Resources {% endcomment %}
{% assign pic_support_heading = product.metafields.custom.pic_support_heading.value %}
{% assign pic_support_resource_titles = product.metafields.custom.pic_support_resource_titles.value %}
{% assign pic_support_resource_descriptions = product.metafields.custom.pic_support_resource_descriptions.value %}
{% comment %} {% assign pic_support_resource_links = product.metafields.custom.pic_support_resource_links.value %} {% endcomment %}
{% assign pic_support_resource_files = product.metafields.custom.pic_support_and_resource_files.value %}
{% assign pic_support_resource_icons = product.metafields.custom.pic_support_resource_icons.value %}

{% comment %} Support Tab - Contact Section (JSON) {% endcomment %}
{% assign pic_support_contact = product.metafields.custom.pic_support_contact.value %}

{% comment %} Support Tab - Use Case Section {% endcomment %}
{% comment %} {% assign pic_support_usecase_image = product.metafields.custom.pic_support_usecase_image.value %}
{% assign pic_support_usecase_title = product.metafields.custom.pic_support_usecase_title.value %}
{% assign pic_support_usecase_description = product.metafields.custom.pic_support_usecase_description.value %}
{% assign pic_support_usecase_specs = product.metafields.custom.pic_support_usecase_specs.value %}
{% assign pic_support_usecase_config = product.metafields.custom.pic_support_usecase_config.value %}
{% assign pic_support_usecase_features_title = product.metafields.custom.pic_support_usecase_features_title.value %}
{% assign pic_support_usecase_features = product.metafields.custom.pic_support_usecase_features.value %} {% endcomment %}

{% comment %} Overview Tab {% endcomment %}
{% assign pic_overview_description = product.metafields.custom.pic_overview_description.value %}
{% assign pic_overview_image = product.metafields.custom.pic_overview_image.value %}
{% assign pic_overview_card_titles = product.metafields.custom.pic_overview_card_titles.value %}
{% assign pic_overview_card_descriptions = product.metafields.custom.pic_overview_card_descriptions.value %}

<section class="product-intelligence {{ section.settings.custom_class }}" id="product-intelligence-{{ section.id }}">
  <div class="product-intelligence__container">
    <!-- Header -->
    <div class="product-intelligence__header">
      <div class="product-intelligence__header-text">
        {% if pic_label != blank %}
          <span class="product-intelligence__label">{{ pic_label }}</span>
        {% endif %}
        {% if pic_heading != blank %}
          <h2 class="product-intelligence__heading">{{ pic_heading }}</h2>
        {% endif %}
      </div>
      {% if pic_subheading != blank %}
        <p class="product-intelligence__subheading">{{ pic_subheading }}</p>
      {% endif %}
    </div>

    <!-- Content -->
    <div class="product-intelligence__content">
      <!-- Tab Navigation -->
      <div class="product-intelligence__tabs" role="tablist">
        {% for block in section.blocks %}
          {% if block.type == 'tab' or block.type == 'specs_tab' or block.type == 'overview_tab' or block.type == 'features_tab' or block.type == 'included_tab' or block.type == 'installation_tab' or block.type == 'support_tab' %}
            <button
              class="product-intelligence__tab {% if forloop.first %}product-intelligence__tab--active{% endif %}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-controls="panel-{{ block.id }}"
              data-tab-index="{{ forloop.index0 }}"
              {{ block.shopify_attributes }}
            >
              {% case block.settings.tab_icon %}
                {% when 'overview' %}
                  <svg class="product-intelligence__tab-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="14" viewBox="0 0 18 14" fill="none">
                    <path d="M8.99922 0C6.47422 0 4.45234 1.15 2.98047 2.51875C1.51797 3.875 0.539844 5.5 0.0773437 6.61562C-0.0257813 6.8625 -0.0257813 7.1375 0.0773437 7.38437C0.539844 8.5 1.51797 10.125 2.98047 11.4812C4.45234 12.85 6.47422 14 8.99922 14C11.5242 14 13.5461 12.85 15.018 11.4812C16.4805 10.1219 17.4586 8.5 17.9242 7.38437C18.0273 7.1375 18.0273 6.8625 17.9242 6.61562C17.4586 5.5 16.4805 3.875 15.018 2.51875C13.5461 1.15 11.5242 0 8.99922 0ZM4.49922 7C4.49922 5.80653 4.97332 4.66193 5.81724 3.81802C6.66115 2.97411 7.80574 2.5 8.99922 2.5C10.1927 2.5 11.3373 2.97411 12.1812 3.81802C13.0251 4.66193 13.4992 5.80653 13.4992 7C13.4992 8.19347 13.0251 9.33807 12.1812 10.182C11.3373 11.0259 10.1927 11.5 8.99922 11.5C7.80574 11.5 6.66115 11.0259 5.81724 10.182C4.97332 9.33807 4.49922 8.19347 4.49922 7ZM8.99922 5C8.99922 6.10313 8.10234 7 6.99922 7C6.77734 7 6.56484 6.9625 6.36484 6.89687C6.19297 6.84062 5.99297 6.95312 5.99922 7.13437C6.00859 7.36875 6.04297 7.60312 6.10234 7.81875C6.53047 9.41875 8.17734 10.3719 9.77734 9.94375C11.3773 9.51562 12.3305 7.86875 11.9023 6.26875C11.5555 5.00625 10.4086 4.13125 9.12734 4.07812C8.94609 4.07187 8.83984 4.26875 8.89609 4.44375C8.96172 4.64375 8.99922 4.85625 8.99922 5Z" fill="currentColor"/>
                  </svg>
                {% when 'specs' %}
                  <svg class="product-intelligence__tab-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="21" viewBox="0 0 24 21" fill="none">
                    <path d="M7.12971 0.294548C7.59377 0.711735 7.63127 1.41955 7.21409 1.88361L3.83909 5.63361C3.63284 5.8633 3.34221 5.99923 3.03284 6.00392C2.72346 6.00861 2.42815 5.89142 2.20784 5.6758L0.328149 3.8008C-0.107788 3.36017 -0.107788 2.64767 0.328149 2.20705C0.764087 1.76642 1.48127 1.76642 1.91721 2.20705L2.95315 3.24299L5.53596 0.374235C5.95315 -0.0898272 6.66096 -0.127327 7.12502 0.28986L7.12971 0.294548ZM7.12971 7.79455C7.59377 8.21173 7.63127 8.91955 7.21409 9.38361L3.83909 13.1336C3.63284 13.3633 3.34221 13.4992 3.03284 13.5039C2.72346 13.5086 2.42815 13.3914 2.20784 13.1758L0.328149 11.3008C-0.112476 10.8602 -0.112476 10.1477 0.328149 9.71173C0.768774 9.2758 1.48127 9.27111 1.91721 9.71173L2.95315 10.7477L5.53596 7.87892C5.95315 7.41486 6.66096 7.37736 7.12502 7.79455H7.12971ZM10.5 3.00392C10.5 2.17424 11.1703 1.50392 12 1.50392H22.5C23.3297 1.50392 24 2.17424 24 3.00392C24 3.83361 23.3297 4.50392 22.5 4.50392H12C11.1703 4.50392 10.5 3.83361 10.5 3.00392ZM10.5 10.5039C10.5 9.67423 11.1703 9.00392 12 9.00392H22.5C23.3297 9.00392 24 9.67423 24 10.5039C24 11.3336 23.3297 12.0039 22.5 12.0039H12C11.1703 12.0039 10.5 11.3336 10.5 10.5039ZM7.50002 18.0039C7.50002 17.1742 8.17034 16.5039 9.00002 16.5039H22.5C23.3297 16.5039 24 17.1742 24 18.0039C24 18.8336 23.3297 19.5039 22.5 19.5039H9.00002C8.17034 19.5039 7.50002 18.8336 7.50002 18.0039ZM2.25002 15.7539C2.84676 15.7539 3.41906 15.991 3.84101 16.4129C4.26297 16.8349 4.50002 17.4072 4.50002 18.0039C4.50002 18.6007 4.26297 19.173 3.84101 19.5949C3.41906 20.0169 2.84676 20.2539 2.25002 20.2539C1.65329 20.2539 1.08099 20.0169 0.659034 19.5949C0.237077 19.173 2.44007e-05 18.6007 2.44007e-05 18.0039C2.44007e-05 17.4072 0.237077 16.8349 0.659034 16.4129C1.08099 15.991 1.65329 15.7539 2.25002 15.7539Z" fill="currentColor"/>
                  </svg>
                {% when 'features' %}
                  <svg class="product-intelligence__tab-icon" xmlns="http://www.w3.org/2000/svg" width="23" height="20" viewBox="0 0 23 20" fill="none">
                    <g clip-path="url(#clip_tab_features)">
                      <path d="M12.3789 0.703125C12.1719 0.273438 11.7344 0 11.2539 0C10.7734 0 10.3399 0.273438 10.1289 0.703125L7.6172 5.87109L2.00782 6.69922C1.53907 6.76953 1.14845 7.09766 1.00391 7.54688C0.859383 7.99609 0.97657 8.49219 1.31251 8.82422L5.38282 12.8516L4.42188 18.543C4.34376 19.0117 4.53907 19.4883 4.92579 19.7656C5.31251 20.043 5.82423 20.0781 6.2461 19.8555L11.2578 17.1797L16.2695 19.8555C16.6914 20.0781 17.2031 20.0469 17.5899 19.7656C17.9766 19.4844 18.1719 19.0117 18.0938 18.543L17.1289 12.8516L21.1992 8.82422C21.5352 8.49219 21.6563 7.99609 21.5078 7.54688C21.3594 7.09766 20.9727 6.76953 20.5039 6.69922L14.8906 5.87109L12.3789 0.703125Z" fill="currentColor"/>
                    </g>
                    <defs><clipPath id="clip_tab_features"><path d="M0 0H22.5V20H0V0Z" fill="white"/></clipPath></defs>
                  </svg>
                {% when 'included' %}
                  <svg class="product-intelligence__tab-icon" xmlns="http://www.w3.org/2000/svg" width="21" height="21" viewBox="0 0 21 21" fill="none">
                    <path d="M2.37656 1.24219L0 6H9.75V0H4.39219C3.53906 0 2.76094 0.482812 2.37656 1.24219ZM11.25 6H21L18.6234 1.24219C18.2391 0.482812 17.4609 0 16.6078 0H11.25V6ZM21 7.5H0V18C0 19.6547 1.34531 21 3 21H18C19.6547 21 21 19.6547 21 18V7.5Z" fill="currentColor"/>
                  </svg>
                {% when 'installation' %}
                  <svg class="product-intelligence__tab-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <g clip-path="url(#clip_tab_install)">
                      <path d="M3.07032 0.195782C2.69923 -0.0932804 2.17188 -0.0581242 1.83595 0.273907L0.273446 1.83641C-0.0585854 2.16844 -0.0937417 2.69578 0.191415 3.07078L3.31641 7.13328C3.4922 7.36375 3.76954 7.50047 4.0586 7.50047H6.17188L10.4297 11.7583C9.85548 12.8911 10.0391 14.313 10.9883 15.2583L15.3633 19.6333C15.8516 20.1216 16.6445 20.1216 17.1328 19.6333L19.6328 17.1333C20.1211 16.645 20.1211 15.852 19.6328 15.3638L15.2578 10.9888C14.3125 10.0434 12.8906 9.85594 11.7578 10.4302L7.50001 6.17234V4.06297C7.50001 3.77 7.36329 3.49656 7.13282 3.32078L3.07032 0.195782ZM0.777352 15.4731C0.281258 15.9692 8.31718e-06 16.645 8.31718e-06 17.3481C8.31718e-06 18.813 1.18751 20.0005 2.65235 20.0005C3.35548 20.0005 4.03126 19.7192 4.52735 19.2231L9.12891 14.6216C8.82423 13.8052 8.77735 12.9184 8.98829 12.0786L6.57813 9.66844L0.777352 15.4731ZM20 5.62547C20 5.21531 19.957 4.81688 19.875 4.43406C19.7813 3.99656 19.2461 3.88328 18.9297 4.19969L16.4336 6.69578C16.3164 6.81297 16.1563 6.87938 15.9922 6.87938H13.75C13.4063 6.87938 13.125 6.59813 13.125 6.25438V4.00828C13.125 3.84422 13.1914 3.68406 13.3086 3.56688L15.8047 1.07078C16.1211 0.754376 16.0078 0.21922 15.5703 0.12547C15.1836 0.0434383 14.7852 0.000469576 14.375 0.000469576C11.2695 0.000469576 8.75001 2.52 8.75001 5.62547V5.65672L12.082 8.98875C13.4883 8.63328 15.043 9.00828 16.1445 10.1098L16.7578 10.7231C18.6719 9.82469 20 7.87938 20 5.62547ZM2.18751 16.8755C2.18751 16.6268 2.28628 16.3884 2.4621 16.2126C2.63791 16.0367 2.87637 15.938 3.12501 15.938C3.37365 15.938 3.61211 16.0367 3.78792 16.2126C3.96374 16.3884 4.06251 16.6268 4.06251 16.8755C4.06251 17.1241 3.96374 17.3626 3.78792 17.5384C3.61211 17.7142 3.37365 17.813 3.12501 17.813C2.87637 17.813 2.63791 17.7142 2.4621 17.5384C2.28628 17.3626 2.18751 17.1241 2.18751 16.8755Z" fill="currentColor"/>
                    </g>
                    <defs><clipPath id="clip_tab_install"><path d="M0 0H20V20H0V0Z" fill="white"/></clipPath></defs>
                  </svg>
                {% when 'support' %}
                  <svg class="product-intelligence__tab-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <g clip-path="url(#clip_tab_support)">
                      <path d="M10 1.875C5.51172 1.875 1.875 5.51172 1.875 10V11.5625C1.875 12.082 1.45703 12.5 0.9375 12.5C0.417969 12.5 0 12.082 0 11.5625V10C0 4.47656 4.47656 0 10 0C15.5234 0 20 4.47656 20 10V15.6289C20 17.5273 18.4609 19.0664 16.5586 19.0664L12.25 19.0625C11.9258 19.6211 11.3203 20 10.625 20H9.375C8.33984 20 7.5 19.1602 7.5 18.125C7.5 17.0898 8.33984 16.25 9.375 16.25H10.625C11.3203 16.25 11.9258 16.6289 12.25 17.1875L16.5625 17.1914C17.4258 17.1914 18.125 16.4922 18.125 15.6289V10C18.125 5.51172 14.4883 1.875 10 1.875ZM5.625 8.125H6.25C6.94141 8.125 7.5 8.68359 7.5 9.375V13.75C7.5 14.4414 6.94141 15 6.25 15H5.625C4.24609 15 3.125 13.8789 3.125 12.5V10.625C3.125 9.24609 4.24609 8.125 5.625 8.125ZM14.375 8.125C15.7539 8.125 16.875 9.24609 16.875 10.625V12.5C16.875 13.8789 15.7539 15 14.375 15H13.75C13.0586 15 12.5 14.4414 12.5 13.75V9.375C12.5 8.68359 13.0586 8.125 13.75 8.125H14.375Z" fill="currentColor"/>
                    </g>
                    <defs><clipPath id="clip_tab_support"><path d="M0 0H20V20H0V0Z" fill="white"/></clipPath></defs>
                  </svg>
                {% else %}
                  <svg class="product-intelligence__tab-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="14" viewBox="0 0 18 14" fill="none">
                    <path d="M8.99922 0C6.47422 0 4.45234 1.15 2.98047 2.51875C1.51797 3.875 0.539844 5.5 0.0773437 6.61562C-0.0257813 6.8625 -0.0257813 7.1375 0.0773437 7.38437C0.539844 8.5 1.51797 10.125 2.98047 11.4812C4.45234 12.85 6.47422 14 8.99922 14C11.5242 14 13.5461 12.85 15.018 11.4812C16.4805 10.1219 17.4586 8.5 17.9242 7.38437C18.0273 7.1375 18.0273 6.8625 17.9242 6.61562C17.4586 5.5 16.4805 3.875 15.018 2.51875C13.5461 1.15 11.5242 0 8.99922 0ZM4.49922 7C4.49922 5.80653 4.97332 4.66193 5.81724 3.81802C6.66115 2.97411 7.80574 2.5 8.99922 2.5C10.1927 2.5 11.3373 2.97411 12.1812 3.81802C13.0251 4.66193 13.4992 5.80653 13.4992 7C13.4992 8.19347 13.0251 9.33807 12.1812 10.182C11.3373 11.0259 10.1927 11.5 8.99922 11.5C7.80574 11.5 6.66115 11.0259 5.81724 10.182C4.97332 9.33807 4.49922 8.19347 4.49922 7Z" fill="currentColor"/>
                  </svg>
              {% endcase %}
              {{ block.settings.tab_title }}
            </button>
          {% endif %}
        {% endfor %}
      </div>

      <!-- Mobile Dropdown -->
      <div class="product-intelligence__dropdown">
        <select class="product-intelligence__select" aria-label="Select tab">
          {% for block in section.blocks %}
            {% if block.type == 'tab' or block.type == 'specs_tab' or block.type == 'overview_tab' or block.type == 'features_tab' or block.type == 'included_tab' or block.type == 'installation_tab' or block.type == 'support_tab' %}
              <option value="{{ forloop.index0 }}">{{ block.settings.tab_title }}</option>
            {% endif %}
          {% endfor %}
        </select>
      </div>

      <!-- Tab Panels -->
      <div class="product-intelligence__panels">
        {% for block in section.blocks %}
          {% if block.type == 'tab' %}
            <div
              class="product-intelligence__panel {% if forloop.first %}product-intelligence__panel--active{% endif %}"
              role="tabpanel"
              id="panel-{{ block.id }}"
              data-panel-index="{{ forloop.index0 }}"
            >
              <div class="product-intelligence__panel-content">
                <!-- Left Side: Text + Feature Cards -->
                <div class="product-intelligence__left">
                  <div class="product-intelligence__text">
                    <p>Meet the Brightlink Pro Spectrum COB LED Video Wall in our 217" Diagonal configuration. This 15.75' x 8.86' masterpiece delivers 8,294,400 pixels at 1.25mm pitch - true 4K resolution with HDR support.</p>
                    <p>The Pro Spectrum represents the pinnacle of COB technology. True pixel-to-LED resolution, high dynamic range, and superior contrast deliver visuals that feel alive.</p>
                    {% if block.settings.read_more_link != blank %}
                      <a href="{{ block.settings.read_more_link }}" class="product-intelligence__read-more">Read More</a>
                    {% endif %}
                  </div>

                  <!-- Feature Cards -->
                  {% if block.settings.show_features %}
                    <div class="product-intelligence__features">
                      <!-- Feature 1: 4-Year Warranty -->
                      <div class="product-intelligence__feature-card">
                        <div class="product-intelligence__feature-icon">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
                          </svg>
                        </div>
                        <h4 class="product-intelligence__feature-title">4-Year Warranty</h4>
                        <p class="product-intelligence__feature-desc">Comprehensive coverage</p>
                      </div>

                      <!-- Feature 2: Lifetime Support -->
                      <div class="product-intelligence__feature-card">
                        <div class="product-intelligence__feature-icon">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <path d="M12 1c-4.97 0-9 4.03-9 9v7c0 1.66 1.34 3 3 3h3v-8H5v-2c0-3.87 3.13-7 7-7s7 3.13 7 7v2h-4v8h3c1.66 0 3-1.34 3-3v-7c0-4.97-4.03-9-9-9z"/>
                          </svg>
                        </div>
                        <h4 class="product-intelligence__feature-title">Lifetime Support</h4>
                        <p class="product-intelligence__feature-desc">855-449-4733</p>
                      </div>

                      <!-- Feature 3: 5% Spare Parts -->
                      <div class="product-intelligence__feature-card">
                        <div class="product-intelligence__feature-icon">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                            <path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/>
                          </svg>
                        </div>
                        <h4 class="product-intelligence__feature-title">5% Spare Parts</h4>
                        <p class="product-intelligence__feature-desc">Included standard</p>
                      </div>
                    </div>
                  {% endif %}
                </div>

                <!-- Right Side: Image Placeholder -->
                <div class="product-intelligence__right">
                  <div class="product-intelligence__image-placeholder">
                    <span>Add Image via Metafields</span>
                  </div>
                </div>
              </div>
            </div>
          {% elsif block.type == 'overview_tab' %}
            <div
              class="product-intelligence__panel {% if forloop.first %}product-intelligence__panel--active{% endif %}"
