                              <span class="resource-card__size" data-file-url="{{ file_url }}">Calculating...</span>
                            {% comment %} {% else %}
                              <span class="resource-card__badge"></span>
                              <span class="resource-card__size"></span> {% endcomment %}
                            {% endif %}
                          </div>
                        </div>
                      {% endfor %}
