<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('product-intelligence-{{ section.id }}');
    if (!section) return;

    const tabs = section.querySelectorAll('.product-intelligence__tab');
    const panels = section.querySelectorAll('.product-intelligence__panel');
    let currentIndex = 0;

    const dropdown = section.querySelector('.product-intelligence__select');

    // Function to switch tabs
    function switchToTab(index) {
      if (index === currentIndex) return;

      // Determine slide direction
      const slideDirection = index > currentIndex ? 'slide-right' : 'slide-left';

      // Remove active class from all tabs and panels
      tabs.forEach(t => {
        t.classList.remove('product-intelligence__tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach(p => {
        p.classList.remove('product-intelligence__panel--active');
        p.classList.remove('product-intelligence__panel--slide-right');
        p.classList.remove('product-intelligence__panel--slide-left');
      });

      // Add active class to clicked tab and corresponding panel
      if (tabs[index]) {
        tabs[index].classList.add('product-intelligence__tab--active');
        tabs[index].setAttribute('aria-selected', 'true');
      }
      if (panels[index]) {
        panels[index].classList.add('product-intelligence__panel--active');
        panels[index].classList.add('product-intelligence__panel--' + slideDirection);
      }

      // Update dropdown
      if (dropdown) {
        dropdown.value = index;
      }

      // Update current index
      currentIndex = index;
    }

    // Tab click events
    tabs.forEach((tab, index) => {
      tab.addEventListener('click', function() {
        switchToTab(index);
      });
    });

    // Dropdown change event
    if (dropdown) {
      dropdown.addEventListener('change', function() {
        switchToTab(parseInt(this.value, 10));
      });
    }

    // Accordion functionality for specs tab
    const accordions = section.querySelectorAll('[data-accordion]');
    accordions.forEach(accordion => {
      const header = accordion.querySelector('.specs-accordion__header');
      if (header) {
        header.addEventListener('click', function() {
          accordion.classList.toggle('specs-accordion--open');
        });
      }
    });

    // Read More toggle functionality
    const readMoreToggles = section.querySelectorAll('.product-intelligence__read-more-toggle');
    readMoreToggles.forEach(toggle => {
      toggle.addEventListener('click', function() {
        const left = this.closest('.product-intelligence__left');
        const textEl = left.querySelector('.product-intelligence__text');

        if (textEl.classList.contains('product-intelligence__text--expanded')) {
          textEl.classList.remove('product-intelligence__text--expanded');
          textEl.classList.add('product-intelligence__text--truncated');
          this.textContent = 'Read More';
        } else {
          textEl.classList.remove('product-intelligence__text--truncated');
          textEl.classList.add('product-intelligence__text--expanded');
          this.textContent = 'Read Less';
        }
      });
    });
   // Calculate and display file sizes for resource cards
    const resourceSizeElements = section.querySelectorAll('.resource-card__size[data-file-url]');
    resourceSizeElements.forEach((sizeEl) => {
      const fileUrl = sizeEl.getAttribute('data-file-url');
      if (fileUrl) {
        getFileSize(fileUrl)
          .then((size) => {
            sizeEl.textContent = size;
          })
          .catch(() => {
            sizeEl.textContent = '';
          });
      }
    });
  });

  // Function to format file size
  function formatFileSize(bytes) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  }

  // Function to get file size from URL
  async function getFileSize(url) {
    try {
      const response = await fetch(url, { method: 'HEAD' });
      const contentLength = response.headers.get('Content-Length');
      if (contentLength) {
        return formatFileSize(parseInt(contentLength, 10));
      }
      // If HEAD doesn't return Content-Length, try with GET and abort
      const getResponse = await fetch(url);
      const blob = await getResponse.blob();
      return formatFileSize(blob.size);
    } catch (error) {
      console.error('Error getting file size:', error);
      return '';
    }
  }

  // Function to download resource file
  function downloadResourceFile(fileUrl, fileName) {
    if (!fileUrl) return;
    // Create a temporary anchor element
    const link = document.createElement('a');
    link.href = fileUrl;
    link.download = fileName || fileUrl.split('/').pop().split('?')[0];
    link.target = '_blank';

    // For cross-origin files, we need to fetch and create blob
    fetch(fileUrl)
      .then((response) => response.blob())
      .then((blob) => {
        const blobUrl = window.URL.createObjectURL(blob);
        link.href = blobUrl;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        window.URL.revokeObjectURL(blobUrl);
      })
      .catch((error) => {
        // Fallback: open in new tab if fetch fails
        console.error('Download error:', error);
        window.open(fileUrl, '_blank');
      });
  }

  // Global Add to Cart handler for all ORDER NOW buttons
  if (!window._sectionAddToCartInit) {
    window._sectionAddToCartInit = true;
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.js-section-add-to-cart');
      if (!btn) return;

      var variantId = btn.getAttribute('data-variant-id');
      if (!variantId) return;

      var originalText = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = 'Adding...';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: parseInt(variantId), quantity: 1 }] })
      })
      .then(function(response) {
        if (response.ok) {
          btn.innerHTML = 'Added!';
          // Update cart count and refresh mini-cart
          fetch('/cart.js')
            .then(function(r) { return r.json(); })
            .then(function(cart) {
              document.querySelectorAll('.header__cart-count').forEach(function(el) {
                el.textContent = cart.item_count;
              });
              return fetch((window.routes ? window.routes.cartUrl : '/cart') + '?section_id=mini-cart');
            })
            .then(function(r) { return r.text(); })
            .then(function(html) {
              var miniCart = document.getElementById('mini-cart');
              if (miniCart) {
                var temp = document.createElement('div');
                temp.innerHTML = html;
                var newMiniCart = temp.querySelector('.mini-cart');
                if (newMiniCart) {
                  miniCart.innerHTML = newMiniCart.innerHTML;
                }
              }
            });
          setTimeout(function() {
            btn.innerHTML = originalText;
            btn.disabled = false;
          }, 2000);
        } else {
          btn.innerHTML = 'Error';
          setTimeout(function() {
            btn.innerHTML = originalText;
            btn.disabled = false;
          }, 2000);
        }
      })
      .catch(function() {
        btn.innerHTML = originalText;
        btn.disabled = false;
      });
    });
  }
</script>

