{% comment %}
  Success Stories Section
  Three-column card layout on desktop, infinite slider on mobile
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.background_gradient_start }};
    background: linear-gradient(135deg, {{ section.settings.background_gradient_start }} 0%, {{ section.settings.background_gradient_end }} 100%);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  }

  #shopify-section-{{ section.id }} .success-container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 12px;
  }

  /* Header Section */
  #shopify-section-{{ section.id }} .section-header {
    text-align: center;
    margin-bottom: 65px;
  }

  #shopify-section-{{ section.id }} .section-title {
    color: #FFF;
    text-align: center;
    font-family: Inter;
    font-size: 48px;
    font-style: normal;
    font-weight: 700;
    line-height: 36px;
    margin-bottom: 23.08px;
  }

  #shopify-section-{{ section.id }} .section-subtitle {
    color: #D1D5DB;
    text-align: center;
    font-family: Inter;
    margin: 0;
    font-size: 20px;
    font-style: normal;
    font-weight: 400;
    line-height: 28px;
  }

  /* Desktop Cards Grid */
  #shopify-section-{{ section.id }} .stories-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  #shopify-section-{{ section.id }} .story-card {
    background: #1E293B;
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  #shopify-section-{{ section.id }} .story-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
  }

  #shopify-section-{{ section.id }} .card-image-container {
    position: relative;
    padding-bottom: 56.262%; /* 16:9 aspect ratio */
    overflow: hidden;
    background: {{ section.settings.image_placeholder_bg }};
  }

  #shopify-section-{{ section.id }} .card-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .card-badge {
    border-radius: 9999px;
    border: 0 solid #E5E7EB;
    background: rgba(59, 130, 246, 0.20);
    color: #60A5FA;
    font-family: Inter;
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    padding: 8px 12px;
    text-transform: capitalize;
    /* letter-spacing: 0.3px; */
    display: inline-block;
    margin-bottom: 15px;
  }

  #shopify-section-{{ section.id }} .card-content {
    padding: 25px;
  }

  #shopify-section-{{ section.id }} .card-title {
    color: #FFF;
    font-family: Inter;
    font-size: 20px;
    font-style: normal;
    font-weight: 700;
    line-height: 28px;
    margin: 0 0 15px 0;
  }

  #shopify-section-{{ section.id }} .card-description {
    color: #D1D5DB;
    font-family: Inter;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 24px;
    margin: 0 0 20px 0;
  }

  #shopify-section-{{ section.id }} .card-specs {
    display: flex;
    align-items: center;
    gap: 20px;
    /* margin-top: 15px; */
    margin: 0;
  }

  #shopify-section-{{ section.id }} .spec-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #9CA3AF;
    font-family: Inter;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 20px;
  }

  #shopify-section-{{ section.id }} .spec-icon {
    font-size: 16px;
    display: flex;
    color: {{ section.settings.spec_icon_color }};
  }

  /* Mobile Slider */
  #shopify-section-{{ section.id }} .mobile-slider {
    display: none;
    position: relative;
    padding: 0 20px;
  }

  #shopify-section-{{ section.id }} .slider-wrapper {
    overflow: hidden;
    border-radius: {{ section.settings.card_border_radius }}px;
  }

  #shopify-section-{{ section.id }} .slider-track {
    display: flex;
    transition: transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .slider-slide {
    flex: 0 0 100%;
  }

  #shopify-section-{{ section.id }} .mobile-card {
    border-radius: 16px;
    border: 0 solid #E5E7EB;
    background: #1E293B;
    box-shadow: 0 4px 6px 0 rgba(0, 0, 0, 0.10), 0 10px 15px 0 rgba(0, 0, 0, 0.10);
    overflow: hidden;
  }

  /* Slider Controls Container */
  #shopify-section-{{ section.id }} .slider-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
    margin-top: 24px;
  }

  /* Slider Navigation */
  #shopify-section-{{ section.id }} .slider-nav {
    background: {{ section.settings.nav_button_background }};
    color: {{ section.settings.nav_button_color }};
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    font-size: 20px;
  }

  #shopify-section-{{ section.id }} .slider-nav:hover {
    background: {{ section.settings.nav_button_hover_background }};
  }

  /* Slider Dots */
  #shopify-section-{{ section.id }} .slider-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
  }

  #shopify-section-{{ section.id }} .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: {{ section.settings.dot_inactive_color }};
    cursor: pointer;
    transition: all 0.3s ease;
  }

  #shopify-section-{{ section.id }} .dot.active {
    background: {{ section.settings.dot_active_color }};
    transform: scale(1.2);
  }

  /* Mobile Styles */
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} {
      padding: 38px 0 42px 0;
    }
    #shopify-section-{{ section.id }} .success-container {
      padding: 0;
    }

    #shopify-section-{{ section.id }} .section-header {
      padding: 0 28px;
      margin-bottom: 24px;
    }

    #shopify-section-{{ section.id }} .section-title {
      color: #FFF;
      text-align: center;
      font-family: Inter;
      font-size: 28px;
      font-style: normal;
      font-weight: 700;
      line-height: 32px;
      margin-bottom: 16px;
    }

    #shopify-section-{{ section.id }} .section-subtitle {
      color: #D1D5DB;
    text-align: center;
    font-family: Inter;
    font-size: 14px;
    font-style: normal;
    font-weight: 400;
    line-height: 20px;
    }

    #shopify-section-{{ section.id }} .stories-grid {
      display: none;
    }

    #shopify-section-{{ section.id }} .mobile-slider {
      display: block;
      padding-inline: 28px;
    }

    #shopify-section-{{ section.id }} .card-title {
      font-size: {{ section.settings.mobile_card_title_font_size }}px;
    }

    #shopify-section-{{ section.id }} .card-description {
      font-size: {{ section.settings.mobile_card_description_font_size }}px;
    }
  }
{%- endstyle -%}

