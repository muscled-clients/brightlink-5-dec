<script>
(function() {
  let currentSlide_{{ section.id | replace: '-', '_' }} = 0;
  const totalSlides_{{ section.id | replace: '-', '_' }} = {{ section.blocks.size }};

  window.changeSlide = function(sectionId, direction) {
    if (sectionId !== '{{ section.id }}') return;
    
    currentSlide_{{ section.id | replace: '-', '_' }} += direction;
    
    // Infinite loop logic
    if (currentSlide_{{ section.id | replace: '-', '_' }} >= totalSlides_{{ section.id | replace: '-', '_' }}) {
      currentSlide_{{ section.id | replace: '-', '_' }} = 0;
    } else if (currentSlide_{{ section.id | replace: '-', '_' }} < 0) {
      currentSlide_{{ section.id | replace: '-', '_' }} = totalSlides_{{ section.id | replace: '-', '_' }} - 1;
    }
    
    updateSlider_{{ section.id | replace: '-', '_' }}();
  }

  window.goToSlide = function(sectionId, slideIndex) {
    if (sectionId !== '{{ section.id }}') return;
    
    currentSlide_{{ section.id | replace: '-', '_' }} = slideIndex;
    updateSlider_{{ section.id | replace: '-', '_' }}();
  }

  function updateSlider_{{ section.id | replace: '-', '_' }}() {
    const track = document.getElementById('slider-track-{{ section.id }}');
    const dots = document.querySelectorAll('#slider-dots-{{ section.id }} .dot');
    
    if (track) {
      track.style.transform = `translateX(-${currentSlide_{{ section.id | replace: '-', '_' }} * 100}%)`;
    }
    
    dots.forEach((dot, index) => {
      if (index === currentSlide_{{ section.id | replace: '-', '_' }}) {
        dot.classList.add('active');
      } else {
        dot.classList.remove('active');
      }
    });
  }

  // Touch/Swipe support for mobile
  let startX_{{ section.id | replace: '-', '_' }} = 0;
  let isDragging_{{ section.id | replace: '-', '_' }} = false;

  const track = document.getElementById('slider-track-{{ section.id }}');
  if (track) {
    track.addEventListener('touchstart', function(e) {
      startX_{{ section.id | replace: '-', '_' }} = e.touches[0].clientX;
      isDragging_{{ section.id | replace: '-', '_' }} = true;
    });

    track.addEventListener('touchmove', function(e) {
      if (!isDragging_{{ section.id | replace: '-', '_' }}) return;
      e.preventDefault();
    });

    track.addEventListener('touchend', function(e) {
      if (!isDragging_{{ section.id | replace: '-', '_' }}) return;
      
      const endX = e.changedTouches[0].clientX;
      const diff = startX_{{ section.id | replace: '-', '_' }} - endX;
      
      if (Math.abs(diff) > 50) {
        if (diff > 0) {
          changeSlide('{{ section.id }}', 1);
        } else {
          changeSlide('{{ section.id }}', -1);
        }
      }
      
      isDragging_{{ section.id | replace: '-', '_' }} = false;
    });
  }
})();
</script>

