        </div>
        <div class="pdf-content">
          <h3>{{ section.settings.pdf_title }}</h3>
          {% if section.settings.pdf_description != blank %}
            <p>{{ section.settings.pdf_description }}</p>
          {% endif %}
        </div>
      </a>
    {% else %}
      <div class="pdf-download-block">
        <div class="pdf-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 25 25" fill="none">
  <g clip-path="url(#clip0_31_2761)">
