{% comment %}
  PDF Download & Newsletter Subscription Section
  Two-column section with PDF download and email signup
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.background_gradient_start }};
    background: linear-gradient(135deg, {{ section.settings.background_gradient_start }} 0%, {{ section.settings.background_gradient_end }} 100%);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  }

  #shopify-section-{{ section.id }} .pdf-newsletter-container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  #shopify-section-{{ section.id }} .pdf-newsletter-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: 100%;
    gap: 22px;
    align-items: center;
  }

  /* PDF Download Block */
  #shopify-section-{{ section.id }} .pdf-download-block {
    background: {{ section.settings.card_background }};
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    padding: 35px;
    display: flex;
    align-items: center;
    gap: 24px;
    height: 100%;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    color: inherit;
  }

  #shopify-section-{{ section.id }} .pdf-download-block:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  }

  #shopify-section-{{ section.id }} .pdf-icon {
    background: {{ section.settings.pdf_icon_background }};
    color: {{ section.settings.pdf_icon_color }};
    padding: 18.25px 24.33px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .pdf-content h3 {
    font-size: {{ section.settings.pdf_title_font_size }}px;
    font-weight: 600;
    color: {{ section.settings.pdf_title_color }};
    margin: 0;
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .pdf-content p {
    font-size: {{ section.settings.pdf_description_font_size }}px;
    color: {{ section.settings.pdf_description_color }};
    margin: 0;
    line-height: 1.429;
  }

  /* Newsletter Block */
  #shopify-section-{{ section.id }} .newsletter-block {
    background: {{ section.settings.card_background }};
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    height: 100%;
    padding: 35px;
    display: flex;
    align-items: flex-start;
    gap: 20px;
  }

  #shopify-section-{{ section.id }} .email-icon {
    background: {{ section.settings.email_icon_background }};
    color: {{ section.settings.email_icon_color }};
    width: 73px;
    height: 100%;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .newsletter-content {
    flex: 1;
  }

  #shopify-section-{{ section.id }} .newsletter-content h3 {
    font-size: {{ section.settings.email_title_font_size }}px;
    font-weight: 600;
    color: {{ section.settings.email_title_color }};
    margin: 0 0 5px 0;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .newsletter-form {
    display: flex;
    gap: 0;
  }

  #shopify-section-{{ section.id }} .email-input {
    /* flex: 1; */
    padding: 0 16px;
    border: 0.851px solid {{ section.settings.input_border_color }};
    border-radius: 6.806px;
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
    font-size: 14px;
    background: {{ section.settings.input_background }};
    color: {{ section.settings.input_text_color }};
    font-family: inherit;
  }

  #shopify-section-{{ section.id }} .email-input::placeholder {
    color: {{ section.settings.input_placeholder_color }};
  }

  #shopify-section-{{ section.id }} .email-input:focus {
    outline: none;
    border-color: {{ section.settings.input_focus_border_color }};
  }

  #shopify-section-{{ section.id }} .send-button {
    padding: 6px 24px;
    background: {{ section.settings.send_button_background }};
    color: {{ section.settings.send_button_text_color }};
    border: 2px solid {{ section.settings.send_button_border_color }};
    border-radius: 8px;
    border-top-left-radius: 0;
    border-bottom-left-radius: 0;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .send-button:hover {
    background: {{ section.settings.send_button_hover_background }};
    border-color: {{ section.settings.send_button_hover_border_color }};
    transform: translateY(-1px);
  }

  /* Mobile Layout */
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .pdf-newsletter-container {
      padding: 0 25px;
    }

    #shopify-section-{{ section.id }} .pdf-newsletter-grid {
      /* grid-template-columns: 1fr; */
      justify-content: space-between;
      /* gap: 20px; */
    }

    #shopify-section-{{ section.id }} .pdf-download-block,
    #shopify-section-{{ section.id }} .newsletter-block {
      gap: 18px;
    /* background: #1E3A8A; */
    padding: 20px;
    align-items: center;
    border-radius: 6px;
    border: 0 solid #E5E7EB;
    background: #1E3A8A;
    }

    #shopify-section-{{ section.id }} .pdf-icon,
    #shopify-section-{{ section.id }} .email-icon {
      background: none;
    padding: 0;
    width: auto;
    height: auto;
    }

    #shopify-section-{{ section.id }} .pdf-content h3,
    #shopify-section-{{ section.id }} .newsletter-content h3 {
      color: #FFF;
    /* text-align: center; */
    font-family: Inter;
    font-size: 12px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    text-align: left;
    }

    #shopify-section-{{ section.id }} .pdf-content p {
      font-size: {{ section.settings.mobile_description_font_size }}px;
      display: none;
    }

    #shopify-section-{{ section.id }} .newsletter-form {
      flex-direction: column;
      display: none;
    }

    #shopify-section-{{ section.id }} .send-button {
      width: 100%;
      justify-content: center;
      display: flex;
      align-items: center;
    }
  }
{%- endstyle -%}

<div class="pdf-newsletter-container">
  <div class="pdf-newsletter-grid">
    
    <!-- PDF Download Block -->
