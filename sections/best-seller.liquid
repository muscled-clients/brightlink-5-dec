<style>
  /* ── Section wrapper ───────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .bs-section {
    position: relative;
    padding: 80px 0 100px;
    background: #0A0E1A;
    color: #ffffff;
    overflow: hidden;
  }
  /* ── Optional background image ─────────────────────────────────── */
  #shopify-section-{{ section.id }} .bs-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.18;
    pointer-events: none;
  }

  /* ── Layout container ──────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .bs-container {
    position: relative;
    z-index: 1;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 48px;
  }

  /* ── Header row ────────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .bs-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 36px;
    gap: 16px;
  }

  #shopify-section-{{ section.id }} .bs-eyebrow {
    display: block;
    font-family: 'Inter', 'Open Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    color: #D4AF37;
    margin-bottom: 10px;
  }

  #shopify-section-{{ section.id }} .bs-title {
    font-family: 'Inter', 'Open Sans', sans-serif;
    font-size: 44px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -1.5px;
    color: #ffffff;
    margin: 0;
  }

  /* ── Nav arrows ────────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .bs-controls {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    padding-bottom: 4px;
  }

  #shopify-section-{{ section.id }} .bs-nav-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.06);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
    padding: 0;
    color: #ffffff;
  }

  #shopify-section-{{ section.id }} .bs-nav-btn:hover {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.35);
  }

  #shopify-section-{{ section.id }} .bs-nav-btn svg {
    width: 16px;
    height: 16px;
    display: block;
    fill: none;
    stroke: #ffffff;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── Carousel viewport ─────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .bs-viewport {
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .bs-track {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  #shopify-section-{{ section.id }} .bs-track::-webkit-scrollbar {
    display: none;
  }

  /* ── Product card ──────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .bs-card {
    flex: 0 0 calc((100% - 80px) / 5);
    min-width: 220px;
    display: flex;
    flex-direction: column;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.10);
    background: #111827;
    color: #ffffff;
    text-decoration: none;
    scroll-snap-align: start;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
  }

  #shopify-section-{{ section.id }} .bs-card:hover {
    border-color: rgba(212, 175, 55, 0.45);
    transform: translateY(-3px);
  }

  /* White image panel */
  #shopify-section-{{ section.id }} .bs-card__img-wrap {
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    min-height: 180px;
  }

  #shopify-section-{{ section.id }} .bs-card__img-wrap img {
    max-width: 100%;
    max-height: 150px;
    width: auto;
    height: auto;
    display: block;
    object-fit: contain;
  }

  /* Placeholder */
  #shopify-section-{{ section.id }} .bs-card__img-placeholder {
    width: 100%;
    min-height: 150px;
    background: linear-gradient(135deg, #e8ecf0 0%, #d1d8e0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .bs-card__img-placeholder svg {
    width: 48px;
    height: 48px;
    opacity: 0.35;
  }

  /* Card body */
  #shopify-section-{{ section.id }} .bs-card__body {
    padding: 14px 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  #shopify-section-{{ section.id }} .bs-card__name {
    font-family: 'Inter', 'Open Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    line-height: 1.35;
    color: #ffffff;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .bs-card__desc {
    font-family: 'Inter', 'Open Sans', sans-serif;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.55;
    color: #8A9BB5;
    margin: 0;
    flex: 1;
  }

  #shopify-section-{{ section.id }} .bs-card__price {
    font-family: 'Inter', 'Open Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: #ffffff;
    margin-top: 4px;
  }

  /* ── Responsive ────────────────────────────────────────────────── */
  @media (max-width: 1200px) {
    #shopify-section-{{ section.id }} .bs-card {
      flex-basis: calc((100% - 60px) / 4);
    }
  }

  @media (max-width: 900px) {
    #shopify-section-{{ section.id }} .bs-container {
      padding: 0 24px;
    }
    #shopify-section-{{ section.id }} .bs-title {
      font-size: 32px;
      letter-spacing: -0.8px;
    }
    #shopify-section-{{ section.id }} .bs-card {
      flex-basis: calc((100% - 40px) / 3);
    }
  }

  @media (max-width: 640px) {
    #shopify-section-{{ section.id }} .bs-section {
      padding: 60px 0 72px;
    }
    #shopify-section-{{ section.id }} .bs-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
    #shopify-section-{{ section.id }} .bs-title {
      font-size: 26px;
    }
    #shopify-section-{{ section.id }} .bs-card {
      flex-basis: 220px;
    }
    #shopify-section-{{ section.id }} .bs-card__img-wrap {
      min-height: 150px;
      padding: 16px;
    }
  }
</style>

<section class="bs-section" data-section-id="{{ section.id }}">

  {% if section.settings.background_image != blank %}
    <img
      class="bs-bg-img"
      src="{{ section.settings.background_image | image_url: width: 2200 }}"
      alt="{{ section.settings.background_image.alt | escape }}"
      loading="lazy">
  {% endif %}

  <div class="bs-container">

    <!-- Header -->
    <div class="bs-header">
      <div>
        {% if section.settings.eyebrow != blank %}
          <span class="bs-eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}
        {% if section.settings.title != blank %}
          <h2 class="bs-title">{{ section.settings.title }}</h2>
        {% endif %}
      </div>

      <!-- Prev / Next arrows (inline SVG – no image upload needed) -->
      <div class="bs-controls">
        <button class="bs-nav-btn bs-nav-btn--prev" type="button" aria-label="Previous products">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button class="bs-nav-btn bs-nav-btn--next" type="button" aria-label="Next products">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <polyline points="9 6 15 12 9 18"></polyline>
          </svg>
        </button>
      </div>
    </div>

    <!-- Carousel -->
    <div class="bs-viewport">
      <div class="bs-track">
        {% for block in section.blocks %}
          <a
            class="bs-card"
            href="{{ block.settings.link | default: '#' }}"
            {{ block.shopify_attributes }}>

            <!-- White image panel -->
            <div class="bs-card__img-wrap">
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 480 }}"
                  alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                  loading="lazy">
              {% else %}
                <div class="bs-card__img-placeholder">
                  <svg viewBox="0 0 24 24" fill="none" stroke="#aab4be" stroke-width="1.5"
                       stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                  </svg>
                </div>
              {% endif %}
            </div>

            <!-- Product info -->
            <div class="bs-card__body">
              {% if block.settings.title != blank %}
                <p class="bs-card__name">{{ block.settings.title }}</p>
              {% endif %}
              {% if block.settings.description != blank %}
                <p class="bs-card__desc">{{ block.settings.description }}</p>
              {% endif %}
              {% if block.settings.price != blank %}
                <p class="bs-card__price">{{ block.settings.price }}</p>
              {% endif %}
            </div>

          </a>
        {% endfor %}
      </div>
    </div>

  </div>
</section>

<script>
(function () {
  var section = document.querySelector('#shopify-section-{{ section.id }}');
  if (!section) return;

  var track   = section.querySelector('.bs-track');
  var btnPrev = section.querySelector('.bs-nav-btn--prev');
  var btnNext = section.querySelector('.bs-nav-btn--next');

  if (!track || !btnPrev || !btnNext) return;

  function getScrollAmount() {
    var card = track.querySelector('.bs-card');
    if (!card) return 260;
    var style = window.getComputedStyle(track);
    var gap   = parseFloat(style.gap || style.columnGap || '20') || 20;
    return card.offsetWidth + gap;
  }

  btnPrev.addEventListener('click', function () {
    track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
  });

  btnNext.addEventListener('click', function () {
    track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
  });
})();
</script>

