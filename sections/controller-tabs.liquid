<script>
document.addEventListener('DOMContentLoaded', function() {
  const section = document.querySelector('.controller-tabs');
  if (!section) return;

  const tabs = section.querySelectorAll('.controller-tabs__tab');
  const panels = section.querySelectorAll('.controller-tabs__panel');
  const dropdown = section.querySelector('.controller-tabs__select');
  let currentIndex = 0;

  function switchToTab(newIndex) {
    if (newIndex === currentIndex) return;

    tabs.forEach(t => {
      t.classList.remove('controller-tabs__tab--active');
      t.setAttribute('aria-selected', 'false');
    });
    if (tabs[newIndex]) {
      tabs[newIndex].classList.add('controller-tabs__tab--active');
      tabs[newIndex].setAttribute('aria-selected', 'true');
    }

    panels.forEach(p => {
      p.classList.remove('controller-tabs__panel--active');
      p.classList.remove('controller-tabs__panel--slide-left');
      p.classList.remove('controller-tabs__panel--slide-right');
    });

    const targetPanel = panels[newIndex];
    if (targetPanel) {
      if (newIndex > currentIndex) {
        targetPanel.classList.add('controller-tabs__panel--slide-right');
      } else {
        targetPanel.classList.add('controller-tabs__panel--slide-left');
      }
      targetPanel.classList.add('controller-tabs__panel--active');
    }

    if (dropdown) {
      dropdown.value = newIndex;
    }

    currentIndex = newIndex;
  }

  tabs.forEach((tab, index) => {
    tab.addEventListener('click', function() {
      const newIndex = parseInt(this.dataset.tabIndex);
      switchToTab(newIndex);
    });
  });

  if (dropdown) {
    dropdown.addEventListener('change', function() {
      const newIndex = parseInt(this.value);
      switchToTab(newIndex);
    });
  }

  // Image slider functionality
  section.querySelectorAll('[data-slider]').forEach(function(slider) {
    const track = slider.querySelector('.controller-tabs__slider-track');
    const dots = slider.querySelectorAll('.controller-tabs__slider-dot');

    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        const slideIndex = parseInt(this.dataset.slide);
        track.style.transform = 'translateX(-' + (slideIndex * 100) + '%)';
        dots.forEach(function(d) { d.classList.remove('controller-tabs__slider-dot--active'); });
        this.classList.add('controller-tabs__slider-dot--active');
      });
    });
  });

  // Read More toggle functionality
  const readMoreToggles = section.querySelectorAll('.controller-tabs__read-more-toggle');
  readMoreToggles.forEach(toggle => {
    toggle.addEventListener('click', function() {
      const description = this.closest('.controller-tabs__description');
      const textEl = description.querySelector('.controller-tabs__desc-text');

      if (textEl.classList.contains('controller-tabs__desc-text--expanded')) {
        textEl.classList.remove('controller-tabs__desc-text--expanded');
        this.textContent = 'Read More';
      } else {
        textEl.classList.add('controller-tabs__desc-text--expanded');
        this.textContent = 'Read Less';
      }
    });
  });
});
</script>

