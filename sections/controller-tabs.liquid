{{ 'controller-tabs.css' | asset_url | stylesheet_tag }}

{% comment %} Get LED template data from product metafield {% endcomment %}
{% assign led_data = product.metafields.custom.led_template_data.value %}
{% assign controller_data = led_data.controller %}

<section class="controller-tabs" id="controller-tabs">
  <div class="controller-tabs__container">
    <!-- Header - Use metafield data if available, otherwise use section settings -->
    {% assign ctrl_title = controller_data.title | default: section.settings.title %}
    {% assign ctrl_description = controller_data.description | default: section.settings.subtitle %}

    <div class="controller-tabs__header">
      <div class="controller-tabs__header-text">
        {% if section.settings.label != blank %}
          <span class="controller-tabs__label">{{ section.settings.label }}</span>
        {% endif %}
        <h2 class="controller-tabs__heading">{{ ctrl_title }}</h2>
      </div>
      <p class="controller-tabs__subheading">{{ ctrl_description }}</p>

      {% if section.settings.badge_text != blank %}
        <div class="controller-tabs__badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
          <span>{{ section.settings.badge_text }}</span>
        </div>
      {% endif %}
    </div>

    <div class="controller-tabs__content">
      <!-- Mobile Dropdown Navigation -->
      <div class="controller-tabs__dropdown">
        <select class="controller-tabs__select" aria-label="Select tab">
          {% for block in section.blocks %}
            {% if block.type == 'tab' or block.type == 'tab_slider' %}
              <option value="{{ forloop.index0 }}">{{ block.settings.tab_title }}</option>
            {% endif %}
          {% endfor %}
        </select>
      </div>

      <div class="controller-tabs__tabs" role="tablist">
        {% for block in section.blocks %}
          {% if block.type == 'tab' or block.type == 'tab_slider' %}
            <button
              class="controller-tabs__tab {% if forloop.first %}controller-tabs__tab--active{% endif %}"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-controls="ctrl-panel-{{ block.id }}"
              data-tab-index="{{ forloop.index0 }}"
              {{ block.shopify_attributes }}
            >
              {% case block.settings.icon %}
                {% when 'overview' %}
                  <svg class="controller-tabs__tab-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="14" viewBox="0 0 18 14" fill="none">
                    <path d="M8.99922 0C6.47422 0 4.45234 1.15 2.98047 2.51875C1.51797 3.875 0.539844 5.5 0.0773437 6.61562C-0.0257813 6.8625 -0.0257813 7.1375 0.0773437 7.38437C0.539844 8.5 1.51797 10.125 2.98047 11.4812C4.45234 12.85 6.47422 14 8.99922 14C11.5242 14 13.5461 12.85 15.018 11.4812C16.4805 10.1219 17.4586 8.5 17.9242 7.38437C18.0273 7.1375 18.0273 6.8625 17.9242 6.61562C17.4586 5.5 16.4805 3.875 15.018 2.51875C13.5461 1.15 11.5242 0 8.99922 0ZM4.49922 7C4.49922 5.80653 4.97332 4.66193 5.81724 3.81802C6.66115 2.97411 7.80574 2.5 8.99922 2.5C10.1927 2.5 11.3373 2.97411 12.1812 3.81802C13.0251 4.66193 13.4992 5.80653 13.4992 7C13.4992 8.19347 13.0251 9.33807 12.1812 10.182C11.3373 11.0259 10.1927 11.5 8.99922 11.5C7.80574 11.5 6.66115 11.0259 5.81724 10.182C4.97332 9.33807 4.49922 8.19347 4.49922 7ZM8.99922 5C8.99922 6.10313 8.10234 7 6.99922 7C6.77734 7 6.56484 6.9625 6.36484 6.89687C6.19297 6.84062 5.99297 6.94688 5.99922 7.12813C6.00859 7.34375 6.03984 7.55937 6.09922 7.775C6.52734 9.375 8.17422 10.325 9.77422 9.89688C11.3742 9.46875 12.3242 7.82188 11.8961 6.22188C11.5492 4.925 10.4023 4.05312 9.12734 4C8.94609 3.99375 8.83984 4.19062 8.89609 4.36562C8.96172 4.56562 8.99922 4.77812 8.99922 5Z" fill="currentColor"/>
                  </svg>
                {% when 'integration' %}
                  <svg class="controller-tabs__tab-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M4.75469 1.19344C5.06406 1.47156 5.08906 1.94344 4.81094 2.25281L2.56094 4.75281C2.42344 4.90594 2.22969 4.99656 2.02344 4.99969C1.81719 5.00281 1.62031 4.92469 1.47344 4.78094L0.220312 3.53094C-0.0703125 3.23719 -0.0703125 2.76219 0.220312 2.46844C0.510938 2.17469 0.989063 2.17469 1.27969 2.46844L1.97031 3.15906L3.69219 1.24656C3.97031 0.937186 4.44219 0.912185 4.75156 1.19031L4.75469 1.19344ZM4.75469 6.19344C5.06406 6.47156 5.08906 6.94344 4.81094 7.25281L2.56094 9.75281C2.42344 9.90594 2.22969 9.99656 2.02344 9.99969C1.81719 10.0028 1.62031 9.92469 1.47344 9.78094L0.220312 8.53094C-0.0734375 8.23719 -0.0734375 7.76219 0.220312 7.47156C0.514062 7.18094 0.989063 7.17781 1.27969 7.47156L1.97031 8.16219L3.69219 6.24969C3.97031 5.94031 4.44219 5.91531 4.75156 6.19344H4.75469ZM7.00156 2.99969C7.00156 2.44656 7.44844 1.99969 8.00156 1.99969H15.0016C15.5547 1.99969 16.0016 2.44656 16.0016 2.99969C16.0016 3.55281 15.5547 3.99969 15.0016 3.99969H8.00156C7.44844 3.99969 7.00156 3.55281 7.00156 2.99969ZM7.00156 7.99969C7.00156 7.44656 7.44844 6.99969 8.00156 6.99969H15.0016C15.5547 6.99969 16.0016 7.44656 16.0016 7.99969C16.0016 8.55281 15.5547 8.99969 15.0016 8.99969H8.00156C7.44844 8.99969 7.00156 8.55281 7.00156 7.99969ZM5.00156 12.9997C5.00156 12.4466 5.44844 11.9997 6.00156 11.9997H15.0016C15.5547 11.9997 16.0016 12.4466 16.0016 12.9997C16.0016 13.5528 15.5547 13.9997 15.0016 13.9997H6.00156C5.44844 13.9997 5.00156 13.5528 5.00156 12.9997ZM1.50156 11.4997C1.89939 11.4997 2.28092 11.6577 2.56222 11.939C2.84353 12.2203 3.00156 12.6019 3.00156 12.9997C3.00156 13.3975 2.84353 13.779 2.56222 14.0603C2.28092 14.3417 1.89939 14.4997 1.50156 14.4997C1.10374 14.4997 0.722207 14.3417 0.440902 14.0603C0.159598 13.779 0.00156249 13.3975 0.00156249 12.9997C0.00156249 12.6019 0.159598 12.2203 0.440902 11.939C0.722207 11.6577 1.10374 11.4997 1.50156 11.4997Z" fill="currentColor"/>
                  </svg>
                {% when '4k' %}
                  <svg class="controller-tabs__tab-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="16" viewBox="0 0 18 16" fill="none">
                    <path d="M2.04861 0C0.884201 0 -0.0625 0.896875 -0.0625 2V11C-0.0625 12.1031 0.884201 13 2.04861 13H7.85417L7.50122 14H5.21528C4.63142 14 4.15972 14.4469 4.15972 15C4.15972 15.5531 4.63142 16 5.21528 16H13.6597C14.2436 16 14.7153 15.5531 14.7153 15C14.7153 14.4469 14.2436 14 13.6597 14H11.3738L11.0208 13H16.8264C17.9908 13 18.9375 12.1031 18.9375 11V2C18.9375 0.896875 17.9908 0 16.8264 0H2.04861ZM16.8264 2V11H2.04861V2H16.8264Z" fill="currentColor"/>
                  </svg>
                {% when 'processing' %}
                  <svg class="controller-tabs__tab-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M0 8C0 5.87827 0.842855 3.84344 2.34315 2.34315C3.84344 0.842855 5.87827 0 8 0C10.1217 0 12.1566 0.842855 13.6569 2.34315C15.1571 3.84344 16 5.87827 16 8C16 10.1217 15.1571 12.1566 13.6569 13.6569C12.1566 15.1571 10.1217 16 8 16C5.87827 16 3.84344 15.1571 2.34315 13.6569C0.842855 12.1566 0 10.1217 0 8ZM9 3C9 2.73478 8.89464 2.48043 8.70711 2.29289C8.51957 2.10536 8.26522 2 8 2C7.73478 2 7.48043 2.10536 7.29289 2.29289C7.10536 2.48043 7 2.73478 7 3C7 3.26522 7.10536 3.51957 7.29289 3.70711C7.48043 3.89464 7.73478 4 8 4C8.26522 4 8.51957 3.89464 8.70711 3.70711C8.89464 3.51957 9 3.26522 9 3ZM8 13C9.10312 13 10 12.1031 10 11C10 10.4563 9.78438 9.96562 9.43437 9.60625L11.4375 5.05312C11.6031 4.675 11.4313 4.23125 11.0531 4.06563C10.675 3.9 10.2312 4.07187 10.0656 4.45L8.05937 9C8.04062 9 8.01875 9 8 9C6.89687 9 6 9.89688 6 11C6 12.1031 6.89687 13 8 13ZM5.5 4.5C5.5 4.23478 5.39464 3.98043 5.20711 3.79289C5.01957 3.60536 4.76522 3.5 4.5 3.5C4.23478 3.5 3.98043 3.60536 3.79289 3.79289C3.60536 3.98043 3.5 4.23478 3.5 4.5C3.5 4.76522 3.60536 5.01957 3.79289 5.20711C3.98043 5.39464 4.23478 5.5 4.5 5.5C4.76522 5.5 5.01957 5.39464 5.20711 5.20711C5.39464 5.01957 5.5 4.76522 5.5 4.5ZM3 9C3.26522 9 3.51957 8.89464 3.70711 8.70711C3.89464 8.51957 4 8.26522 4 8C4 7.73478 3.89464 7.48043 3.70711 7.29289C3.51957 7.10536 3.26522 7 3 7C2.73478 7 2.48043 7.10536 2.29289 7.29289C2.10536 7.48043 2 7.73478 2 8C2 8.26522 2.10536 8.51957 2.29289 8.70711C2.48043 8.89464 2.73478 9 3 9ZM14 8C14 7.73478 13.8946 7.48043 13.7071 7.29289C13.5196 7.10536 13.2652 7 13 7C12.7348 7 12.4804 7.10536 12.2929 7.29289C12.1054 7.48043 12 7.73478 12 8C12 8.26522 12.1054 8.51957 12.2929 8.70711C12.4804 8.89464 12.7348 9 13 9C13.2652 9 13.5196 8.89464 13.7071 8.70711C13.8946 8.51957 14 8.26522 14 8Z" fill="currentColor"/>
                  </svg>
                {% when 'quality' %}
                  <svg class="controller-tabs__tab-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M2.45714 0.156626C2.16026 -0.0746243 1.73839 -0.0464993 1.46964 0.219126L0.219636 1.46913C-0.0459894 1.73475 -0.0741144 2.15663 0.154011 2.45663L2.65401 5.70663C2.79464 5.891 3.01651 6.00038 3.24776 6.00038H4.93839L8.34464 9.40663C7.88526 10.3129 8.03214 11.4504 8.79151 12.2066L12.2915 15.7066C12.6821 16.0973 13.3165 16.0973 13.7071 15.7066L15.7071 13.7066C16.0978 13.316 16.0978 12.6816 15.7071 12.291L12.2071 8.791C11.4509 8.03475 10.3134 7.88475 9.40714 8.34413L6.00089 4.93788V3.25038C6.00089 3.016 5.89151 2.79725 5.70714 2.65663L2.45714 0.156626ZM0.622761 12.3785C0.225886 12.7754 0.00088556 13.316 0.00088556 13.8785C0.00088556 15.0504 0.950886 16.0004 2.12276 16.0004C2.68526 16.0004 3.22589 15.7754 3.62276 15.3785L7.30401 11.6973C7.06026 11.0441 7.02276 10.3348 7.19151 9.66288L5.26339 7.73475L0.622761 12.3785ZM16.0009 4.50038C16.0009 4.17225 15.9665 3.8535 15.9009 3.54725C15.8259 3.19725 15.3978 3.10663 15.1446 3.35975L13.1478 5.35663C13.054 5.45038 12.9259 5.5035 12.7946 5.5035H11.0009C10.7259 5.5035 10.5009 5.2785 10.5009 5.0035V3.20663C10.5009 3.07538 10.554 2.94725 10.6478 2.8535L12.6446 0.856626C12.8978 0.603501 12.8071 0.175376 12.4571 0.100376C12.1478 0.0347507 11.829 0.000375661 11.5009 0.000375661C9.01651 0.000375661 7.00089 2.016 7.00089 4.50038V4.52538L9.66651 7.191C10.7915 6.90663 12.0353 7.20663 12.9165 8.08788L13.4071 8.5785C14.9384 7.85975 16.0009 6.3035 16.0009 4.50038ZM1.75089 13.5004C1.75089 13.3015 1.8299 13.1107 1.97056 12.97C2.11121 12.8294 2.30197 12.7504 2.50089 12.7504C2.6998 12.7504 2.89056 12.8294 3.03122 12.97C3.17187 13.1107 3.25089 13.3015 3.25089 13.5004C3.25089 13.6993 3.17187 13.8901 3.03122 14.0307C2.89056 14.1714 2.6998 14.2504 2.50089 14.2504C2.30197 14.2504 2.11121 14.1714 1.97056 14.0307C1.8299 13.8901 1.75089 13.6993 1.75089 13.5004Z" fill="currentColor"/>
                  </svg>
                {% when 'flexible' %}
                  <svg class="controller-tabs__tab-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 15 15" fill="none">
                    <path d="M6.81152 0.151626C7.24805 -0.050542 7.75195 -0.050542 8.18848 0.151626L14.5928 3.1109C14.8418 3.22517 15 3.47422 15 3.74963C15 4.02505 14.8418 4.2741 14.5928 4.38837L8.18848 7.34764C7.75195 7.54981 7.24805 7.54981 6.81152 7.34764L0.407227 4.38837C0.158203 4.27117 0 4.02212 0 3.74963C0 3.47715 0.158203 3.22517 0.407227 3.1109L6.81152 0.151626ZM13.0342 6.14049L14.5928 6.86127C14.8418 6.97554 15 7.22458 15 7.5C15 7.77542 14.8418 8.02447 14.5928 8.13873L8.18848 11.098C7.75195 11.3002 7.24805 11.3002 6.81152 11.098L0.407227 8.13873C0.158203 8.02154 0 7.77249 0 7.5C0 7.22751 0.158203 6.97554 0.407227 6.86127L1.96582 6.14049L6.41895 8.19733C7.10449 8.51377 7.89551 8.51377 8.58105 8.19733L13.0342 6.14049ZM8.58105 11.9477L13.0342 9.89086L14.5928 10.6116C14.8418 10.7259 15 10.9749 15 11.2504C15 11.5258 14.8418 11.7748 14.5928 11.8891L8.18848 14.8484C7.75195 15.0505 7.24805 15.0505 6.81152 14.8484L0.407227 11.8891C0.158203 11.7719 0 11.5229 0 11.2504C0 10.9779 0.158203 10.7259 0.407227 10.6116L1.96582 9.89086L6.41895 11.9477C7.10449 12.2641 7.89551 12.2641 8.58105 11.9477Z" fill="currentColor"/>
                  </svg>
                {% else %}
                  <svg class="controller-tabs__tab-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M8 0C3.58 0 0 3.58 0 8s3.58 8 8 8 8-3.58 8-8-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6s2.69-6 6-6 6 2.69 6 6-2.69 6-6 6z" fill="currentColor"/>
                  </svg>
              {% endcase %}
              {{ block.settings.tab_title }}
            </button>
          {% endif %}
        {% endfor %}
      </div>

      <div class="controller-tabs__panels">
        {% for block in section.blocks %}
          {% if block.type == 'tab' or block.type == 'tab_slider' %}
            <div
              class="controller-tabs__panel {% if forloop.first %}controller-tabs__panel--active{% endif %}"
              role="tabpanel"
              id="ctrl-panel-{{ block.id }}"
              data-panel-index="{{ forloop.index0 }}"
            >
              <div class="controller-tabs__panel-content {% if block.settings.layout_type == 'simple' %}controller-tabs__panel-content--simple{% endif %}">
                <div class="controller-tabs__left">
                  <div class="controller-tabs__image-area">
                    {% if block.settings.image_2 != blank and block.settings.image != blank %}
                      <div class="controller-tabs__slider" data-slider>
                        <div class="controller-tabs__slider-track">
                          <img src="{{ block.settings.image | image_url: width: 731 }}" alt="{{ block.settings.tab_title }}" class="controller-tabs__slider-img controller-tabs__slider-img--active" loading="lazy">
                          <img src="{{ block.settings.image_2 | image_url: width: 731 }}" alt="{{ block.settings.tab_title }} - 2" class="controller-tabs__slider-img" loading="lazy">
                        </div>
                        <div class="controller-tabs__slider-dots">
                          <button class="controller-tabs__slider-dot controller-tabs__slider-dot--active" data-slide="0" aria-label="Slide 1"></button>
                          <button class="controller-tabs__slider-dot" data-slide="1" aria-label="Slide 2"></button>
                        </div>
                      </div>
                    {% elsif block.settings.image != blank %}
                      <img src="{{ block.settings.image | image_url: width: 731 }}" alt="{{ block.settings.tab_title }}" class="controller-tabs__product-image" loading="lazy">
                    {% else %}
                      <div class="controller-tabs__image-placeholder">
                        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="rgba(255,255,255,0.1)">
                          <path d="M21 3H3c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H3V5h18v14zM5 15h14v3H5z"/>
                        </svg>
                      </div>
                    {% endif %}
                    {% if forloop.first and block.settings.certified_badge != blank %}
                      <span class="controller-tabs__certified-badge">{{ block.settings.certified_badge }}</span>
                    {% endif %}
                  </div>

                  {% if block.settings.layout_type != 'simple' %}
                    <div class="controller-tabs__config-section">
                      <h4 class="controller-tabs__config-title">{{ block.settings.config_title | default: 'Your Configuration Includes:' }}</h4>
                      <ul class="controller-tabs__config-list">
                        {% if block.settings.config1 != blank %}
                          <li>
                            <span class="controller-tabs__config-dot"></span>
                            {{ block.settings.config1 }}
                          </li>
                        {% endif %}
                        {% if block.settings.config2 != blank %}
                          <li>
                            <span class="controller-tabs__config-dot"></span>
                            {{ block.settings.config2 }}
                          </li>
                        {% endif %}
                        {% if block.settings.config3 != blank %}
                          <li>
                            <span class="controller-tabs__config-dot"></span>
                            {{ block.settings.config3 }}
                          </li>
                        {% endif %}
                        {% if block.settings.config4 != blank %}
                          <li>
                            <span class="controller-tabs__config-dot"></span>
                            {{ block.settings.config4 }}
                          </li>
                        {% endif %}
                        {% if block.settings.config5 != blank %}
                          <li>
                            <span class="controller-tabs__config-dot"></span>
                            {{ block.settings.config5 }}
                          </li>
                        {% endif %}
                      </ul>
                    </div>
                  {% endif %}
                </div>

                <div class="controller-tabs__right">
                  {% if block.settings.layout_type == 'simple' %}
                    <h3 class="controller-tabs__title">{{ block.settings.simple_title | default: block.settings.tab_title }}</h3>
                  {% endif %}

                  <div class="controller-tabs__description">
                    <p class="controller-tabs__desc-text">{{ block.settings.description }}</p>
                    {% if block.settings.layout_type != 'simple' %}
                      {% if block.settings.read_more_link != blank %}
                        <a href="{{ block.settings.read_more_link }}" class="controller-tabs__read-more">Read More</a>
                      {% else %}
                        <button type="button" class="controller-tabs__read-more controller-tabs__read-more-toggle">Read More</button>
                      {% endif %}
                    {% endif %}
                  </div>

                  {% if block.settings.layout_type != 'simple' %}
                    <ul class="controller-tabs__features-list">
                      {% if block.settings.feature1 != blank %}
                        <li>
                          <span class="controller-tabs__feature-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="10" viewBox="0 0 14 10" fill="none">
                              <path d="M13.7086 0.292969C14.0992 0.683594 14.0992 1.31797 13.7086 1.70859L5.70859 9.70859C5.31797 10.0992 4.68359 10.0992 4.29297 9.70859L0.292969 5.70859C-0.0976562 5.31797 -0.0976562 4.68359 0.292969 4.29297C0.683594 3.90234 1.31797 3.90234 1.70859 4.29297L5.00234 7.58359L12.2961 0.292969C12.6867 -0.0976562 13.3211 -0.0976562 13.7117 0.292969H13.7086Z" fill="#0A84FF"/>
                            </svg>
                          </span>
                          {{ block.settings.feature1 }}
                        </li>
                      {% endif %}
                      {% if block.settings.feature2 != blank %}
                        <li>
                          <span class="controller-tabs__feature-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="10" viewBox="0 0 14 10" fill="none">
                              <path d="M13.7086 0.292969C14.0992 0.683594 14.0992 1.31797 13.7086 1.70859L5.70859 9.70859C5.31797 10.0992 4.68359 10.0992 4.29297 9.70859L0.292969 5.70859C-0.0976562 5.31797 -0.0976562 4.68359 0.292969 4.29297C0.683594 3.90234 1.31797 3.90234 1.70859 4.29297L5.00234 7.58359L12.2961 0.292969C12.6867 -0.0976562 13.3211 -0.0976562 13.7117 0.292969H13.7086Z" fill="#0A84FF"/>
                            </svg>
                          </span>
                          {{ block.settings.feature2 }}
                        </li>
                      {% endif %}
                      {% if block.settings.feature3 != blank %}
                        <li>
                          <span class="controller-tabs__feature-icon">
